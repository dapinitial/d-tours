---
const links = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/drive', label: 'Drive', icon: '📡' },
  { href: '/journal', label: 'Journal', icon: '📓' },
  { href: '/calendar', label: 'Calendar', icon: '📅' },
  { href: '/plan', label: 'Plan', icon: '🗺️' },
  { href: '/rig', label: 'Rig', icon: '🚙' },
  { href: '/gear', label: 'Gear', icon: '🎒' },
  { href: '/skills', label: 'Skills', icon: '🎓' },
  { href: '/cms', label: 'CMS', icon: '🗂️' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand">
      <span class="brand-mark">🚐</span>
      <span class="brand-name">D&#8209;TOURS</span>
      <span class="brand-sub">with Shotgun</span>
    </a>
    <nav class="top-nav">
      {links.map((l) => (
        <a href={l.href} class:list={['navlink', { active: isActive(l.href) }]}>{l.label}</a>
      ))}
    </nav>
    <!-- Mobile-only: Drive lives up here so the bottom tab bar stays at 6 tabs
         (7 was wrapping). Hidden on desktop, where it's in .top-nav. -->
    <a href="/drive" class:list={['drive-mobile', { active: isActive('/drive') }]} aria-label="Drive mode">
      <span class="dm-icon">📡</span><span class="dm-label">Drive</span>
    </a>
  </div>
</header>

<!-- Mobile: app-style bottom tab bar (thumb-reachable). Drop Home (brand logo goes
     home) and Drive (moved to the header) so the 6 tabs fit without wrapping. -->
<nav class="tabbar">
  {links.filter((l) => l.href !== '/' && l.href !== '/drive' && l.href !== '/calendar').map((l) => (
    <a href={l.href} class:list={['tab', { active: isActive(l.href) }]}>
      <span class="tab-icon">{l.icon}</span>
      <span class="tab-label">{l.label}</span>
    </a>
  ))}
</nav>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 1000;
    backdrop-filter: blur(12px);
    background: rgba(10,15,22,.72);
    border-bottom: 1px solid var(--border);
  }
  .bar { display: flex; align-items: center; justify-content: space-between; height: 60px; }
  .brand { display: flex; align-items: baseline; gap: .5rem; color: var(--text); font-weight: 800; letter-spacing: .02em; }
  .brand-mark { font-size: 1.3rem; }
  .brand-name { font-size: 1.1rem; }
  .brand-sub { font-family: var(--font-mono); font-size: .68rem; letter-spacing: .2em; text-transform: uppercase; color: var(--green); }
  .top-nav { display: flex; gap: .35rem; }
  .navlink { padding: .55rem .85rem; border-radius: 999px; font-size: .9rem; color: var(--muted); min-height: 40px; display: inline-flex; align-items: center; }
  .navlink:hover { color: var(--text); background: rgba(255,255,255,.04); }
  .navlink.active { color: var(--green); background: rgba(52,211,153,.1); }

  /* Drive shortcut in the header — phones only (desktop uses .top-nav). */
  .drive-mobile { display: none; }

  /* ── mobile bottom tab bar ── */
  .tabbar { display: none; }
  @media (max-width: 640px) {
    .top-nav { display: none; }            /* hide top links on phones */
    .brand-sub { display: none; }
    .drive-mobile {
      display: inline-flex; align-items: center; gap: .35rem;
      padding: .42rem .72rem; border-radius: 999px;
      font-size: .85rem; font-weight: 600; color: var(--muted);
      background: rgba(255,255,255,.05); border: 1px solid var(--border);
      -webkit-tap-highlight-color: transparent;
    }
    .drive-mobile.active { color: var(--green); background: rgba(52,211,153,.12); border-color: rgba(52,211,153,.3); }
    .drive-mobile .dm-icon { font-size: 1rem; line-height: 1; }
    .tabbar {
      display: grid; grid-template-columns: repeat(6, 1fr);
      position: fixed; left: 0; right: 0; bottom: 0; z-index: 200;
      background: rgba(10,15,22,.92);
      backdrop-filter: blur(14px);
      border-top: 1px solid var(--border);
      padding-bottom: env(safe-area-inset-bottom); /* iPhone home-bar safe area */
    }
    .tab {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 2px; padding: .5rem 0; min-height: 56px; color: var(--muted);
      font-size: .68rem; letter-spacing: .02em; -webkit-tap-highlight-color: transparent;
    }
    .tab-icon { font-size: 1.25rem; line-height: 1; }
    .tab.active { color: var(--green); }
    .tab.active .tab-icon { transform: translateY(-1px); filter: drop-shadow(0 0 8px rgba(52,211,153,.5)); }
  }
</style>
