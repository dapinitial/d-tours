---
import type { Objective } from '../lib/types';
interface Props { objectives: Objective[]; }
const { objectives } = Astro.props;
const sev: Record<string, string> = { low: 'chip', med: 'chip amber', high: 'chip red' };
// WFH-friendly crag vs weekend alpine mission.
const dayBadge: Record<string, { icon: string; label: string }> = {
  crag: { icon: '🪨', label: 'Crag · WFH' },
  alpine: { icon: '⛰️', label: 'Weekend alpine' },
};
---
<div class="table-wrap" data-reveal>
  <table class="data">
    <thead>
      <tr>
        <th>Objective</th>
        <th>Region</th>
        <th>Commitment / Length</th>
        <th>Technical Grade</th>
        <th>Key Hazard</th>
      </tr>
    </thead>
    <tbody>
      {objectives.map((o) => (
        <tr class="clickable" data-href={`/objectives/${o.id}`} title="Open dossier">
          <td><strong><a href={`/objectives/${o.id}`} class="obj-link">{o.name}</a></strong> {(o.beta || o.gpx_url) && <span class="dossier-dot" title="Dossier ready">📋</span>}<div class="tags">{o.discipline && <span class="muted disc">{o.discipline}</span>}{o.day_type && dayBadge[o.day_type] && <span class={`daytag ${o.day_type}`} title={dayBadge[o.day_type].label}>{dayBadge[o.day_type].icon} {dayBadge[o.day_type].label}</span>}</div></td>
          <td class="muted">{o.region}</td>
          <td>{o.commitment}</td>
          <td class="mono">{o.grade}</td>
          <td><span class={sev[o.severity]}>{o.hazard}</span></td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
<p class="muted hint">Tap any row for the full dossier · tap a column header to sort.</p>

<script>
  document.querySelectorAll('tr.clickable[data-href]').forEach((tr) => {
    tr.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a, button')) return; // let real links/sort work
      location.href = (tr as HTMLElement).dataset.href!;
    });
  });
</script>

<style>
  .obj-link { color: var(--text); text-decoration: none; border-bottom: 1px dotted var(--border-2); }
  .obj-link:hover { color: var(--green); border-color: var(--green); }
  tr.clickable { cursor: pointer; transition: background .15s; }
  tr.clickable:hover { background: rgba(52,211,153,.06); }
  tr.clickable:hover .obj-link { color: var(--green); }
  .dossier-dot { font-size: .8rem; }
  .tags { display: flex; flex-wrap: wrap; gap: .35rem; align-items: center; margin-top: .25rem; }
  .disc { font-size: .7rem; text-transform: uppercase; letter-spacing: .1em; }
  .daytag { font-size: .68rem; padding: .1rem .45rem; border-radius: 999px; border: 1px solid var(--border-2); white-space: nowrap; }
  .daytag.crag { color: var(--green-2); border-color: rgba(52,211,153,.4); background: rgba(52,211,153,.08); }
  .daytag.alpine { color: #93c5fd; border-color: rgba(147,197,253,.4); background: rgba(147,197,253,.08); }
  .hint { font-size: .8rem; margin-top: .6rem; }
</style>
