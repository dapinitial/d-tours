---
// Share the trip to people along the way. On phones this opens the native share
// sheet (iMessage / WhatsApp / everything) — the link arrives as a rich OG card.
// On desktop (no Web Share API) it copies the link and shows a brief "✓ copied"
// confirmation. One action — no menu, no separate email button.
interface Props { path?: string; text?: string; label?: string; }
const {
  path = Astro.url.pathname,
  text = 'Follow our Austin → Squamish road trip — I might be passing near you!',
  label = '📲 Share',
} = Astro.props;
const url = new URL(path, Astro.site).href;
---
<span class="share" data-url={url} data-text={text}>
  <button class="btn share-btn" type="button">{label}</button>
  <span class="sm-msg" hidden></span>
</span>

<script>
  document.querySelectorAll('.share').forEach((root) => {
    const url = root.dataset.url, text = root.dataset.text;
    const msg = root.querySelector('.sm-msg');
    const toast = (t) => { if (!msg) return; msg.textContent = t; msg.hidden = false; setTimeout(() => { msg.hidden = true; }, 2200); };
    root.querySelector('.share-btn')?.addEventListener('click', async () => {
      if (navigator.share) {
        try { await navigator.share({ title: 'D-Tours', text, url }); return; }
        catch (e) { if (e?.name === 'AbortError') return; } // user cancelled — do nothing
      }
      try { await navigator.clipboard.writeText(url); toast('✓ link copied'); }
      catch { toast(url); }
    });
  });
</script>

<style>
  .share { display: inline-flex; align-items: center; gap: .5rem; }
  .sm-msg { font-size: .8rem; color: var(--green); }
</style>
