---
import type { Resource, CareLayer } from '../lib/types';
interface Props { resources: Resource[]; }
const { resources } = Astro.props;

const layers: { key: CareLayer; emoji: string; title: string; blurb: string }[] = [
  { key: 'climb', emoji: '🧗', title: 'Climb & Adventure', blurb: 'Trad, sport, scrambles, SUP & e-MTB — the whole quiver.' },
  { key: 'life', emoji: '🛠️', title: 'Life Maintenance', blurb: 'Sleep, showers, laundry, haircuts, gear repair.' },
  { key: 'move', emoji: '🤸', title: 'Move & Mobility', blurb: 'Anti-car-rot coach: yoga, calisthenics, runs, tracks, gyms.' },
  { key: 'weird', emoji: '🌀', title: 'Weird & Wonderful', blurb: 'Meow Wolf, Atlas Obscura, roadside Americana.' },
];
const byLayer = (k: CareLayer) => resources.filter((r) => r.layer === k);
---
<div class="layers">
  {layers.map((l) => (
    <div class="layer-col" data-reveal>
      <div class="layer-head">
        <span class="emoji">{l.emoji}</span>
        <div>
          <h3>{l.title}</h3>
          <p class="muted">{l.blurb}</p>
        </div>
      </div>
      <div class="items">
        {byLayer(l.key).map((r) => (
          <div class="item">
            <div class="i-title">{r.emoji} {r.title}</div>
            <div class="muted i-body">{r.body}</div>
          </div>
        ))}
        {byLayer(l.key).length === 0 && <div class="muted empty">More coming as Shotgun learns the route.</div>}
      </div>
    </div>
  ))}
</div>

<style>
  .layers { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  @media (max-width: 980px) { .layers { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .layers { grid-template-columns: 1fr; } }
  .layer-col { background: linear-gradient(180deg, var(--panel), var(--panel-2)); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.2rem; }
  .layer-head { display: flex; gap: .6rem; margin-bottom: 1rem; }
  .layer-head .emoji { font-size: 1.6rem; }
  .layer-head h3 { margin: 0; font-size: 1.05rem; }
  .layer-head p { font-size: .82rem; margin: .15rem 0 0; }
  .items { display: grid; gap: .7rem; }
  .item { padding: .7rem .8rem; background: rgba(255,255,255,.02); border: 1px solid var(--border); border-radius: 10px; }
  .i-title { font-weight: 600; font-size: .92rem; margin-bottom: .25rem; }
  .i-body { font-size: .82rem; line-height: 1.45; }
  .empty { font-size: .82rem; font-style: italic; }
</style>
