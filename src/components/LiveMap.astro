---
// "Where's David" map — David by default; tap "See the brothers" to overlay
// Derek's route + position and the 🤝 rendezvous points (both at once). Loads
// Leaflet from CDN with a graceful offline fallback. Data from /api/trips.
// Geotagged journal posts (photo EXIF / live position) drop as 📷 pins.
import type { Post } from '../lib/types';
interface Props { posts?: Post[] }
const { posts = [] } = Astro.props;
const thumb320 = (u: string | undefined) => (u && u.startsWith('/img/')) ? `${u}?w=320` : (u ?? null);
const geoPosts = posts
  .filter((p) => typeof p.lat === 'number' && typeof p.lng === 'number' && p.published_at)
  .map((p) => ({ id: p.id, title: p.title, lat: p.lat, lng: p.lng, thumb: thumb320((p.media || []).find((m) => /\.(jpe?g|png|webp|gif|heic)/i.test(m))) }));
---
<div class="map-wrap" data-reveal>
  <script type="application/json" id="geo-posts" set:html={JSON.stringify(geoPosts)}></script>
  <div id="dtours-map" class="map">
    <div class="map-fallback">
      <span class="big">🛰️</span>
      <p>Live map loads here — David's route + current position from the inReach feed.</p>
      <p class="muted">Set <code>MAPSHARE_FEED_URL</code> for the live dot.</p>
    </div>
  </div>
  <div class="legend">
    <button class="chip" type="button" data-layer="david" style="--c:#34d399">● David</button>
    <button class="chip" type="button" data-layer="derek" style="--c:#fb923c">● Derek</button>
    <button class="chip" type="button" data-layer="rdv" style="--c:#fbbf24">◆ rendezvous</button>
    <span class="legend-hint muted">tap to toggle</span>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script>
  async function initMap() {
    // @ts-ignore — Leaflet attaches to window
    const L = window.L; if (!L) return; // offline / CDN blocked → keep fallback
    const el = document.getElementById('dtours-map'); if (!el) return;
    el.innerHTML = '';
    const map = L.map(el, { scrollWheelZoom: false }).setView([44, -106], 4);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19,
    }).addTo(map);

    let data;
    try { data = await (await fetch('/api/trips')).json(); } catch { return; }
    const trips = data.trips || [];
    if (!trips.length) return;

    // Draw one trip's route + stops + current position onto a target layer.
    const drawTrip = (trip, target) => {
      const pts = [];
      // Ghost the road ahead (future + undated) faintly, so the trip's shape is visible
      // without claiming it's travelled; the reached breadcrumb draws solid on top.
      if (trip.ahead && trip.ahead.length) {
        L.polyline(trip.ahead, { color: trip.color, weight: 2, opacity: .2, dashArray: '2 9' }).addTo(target);
        trip.ahead.forEach((c) => pts.push(c));
      }
      L.polyline(trip.route, { color: trip.color, weight: 3, opacity: .8, dashArray: '6 7' }).addTo(target);
      // The REAL path travelled (accumulated GPS breadcrumb): a solid, bright line that
      // follows the actual roads — distinct from the dashed plan through stops.
      if (trip.trail && trip.trail.length > 1) {
        L.polyline(trip.trail, { color: trip.color, weight: 4, opacity: .95, lineJoin: 'round', lineCap: 'round' }).addTo(target);
        trip.trail.forEach((c) => pts.push(c));
      }
      for (const s of (trip.stops || [])) {
        L.circleMarker([s.lat, s.lng], { radius: 4, color: trip.color, fillColor: trip.color, fillOpacity: .9, weight: 1 })
          .addTo(target).bindPopup(`${s.emoji} ${s.name} <span style="opacity:.6">· ${trip.name}</span>`);
      }
      if (trip.position) {
        const p = trip.position;
        // Radar "you are here" ping — pulsing ring + solid dot, in the trip's color.
        const icon = L.divIcon({ className: 'live-pulse-wrap', html: `<span class="live-pulse" style="color:${trip.color}"><i></i><b></b></span>`, iconSize: [0, 0], iconAnchor: [0, 0] });
        L.marker([p.lat, p.lng], { icon, zIndexOffset: 1000 })
          .addTo(target).bindPopup(`<b>${trip.name}</b> · ${p.when}${p.live ? '' : ' <span style="opacity:.6">(approx)</span>'}`);
        pts.push([p.lat, p.lng]); // frame the live dot even when the route hasn't drawn yet
      }
      (trip.route || []).forEach((c) => pts.push(c));
      return pts;
    };

    // Three toggleable layers, each tied to a clickable legend chip.
    const layers = { david: L.layerGroup().addTo(map), derek: L.layerGroup().addTo(map), rdv: L.layerGroup().addTo(map) };
    const allPts = [];
    allPts.push(...drawTrip(trips[0], layers.david));
    for (const trip of trips.slice(1)) allPts.push(...drawTrip(trip, layers.derek));

    // 📷 Geotagged journal posts (photo EXIF / live position) ride with David's layer.
    try {
      const posts = JSON.parse(document.getElementById('geo-posts')?.textContent || '[]');
      for (const p of posts) {
        const thumb = p.thumb ? `<img src="${p.thumb}" style="width:160px;border-radius:8px;display:block;margin-bottom:6px">` : '';
        L.marker([p.lat, p.lng], { icon: L.divIcon({ className: 'post-pin', html: '📷', iconSize: [24, 24] }) })
          .addTo(layers.david).bindPopup(`${thumb}<b>${p.title}</b><br><a href="/journal/${p.id}">read →</a>`);
      }
    } catch {}

    // 🤝 Rendezvous markers (with live per-rig ETAs) on their own layer.
    for (const r of (data.rendezvous || [])) {
      const etaRows = (r.etas || []).map((e) =>
        `<div style="display:flex;justify-content:space-between;gap:12px"><span style="color:${e.color}">●&nbsp;${e.name}</span><span>~${e.hours}h${e.live ? '' : ' <i style="opacity:.5">approx</i>'}</span></div>`).join('');
      const conv = r.converge != null && (r.etas || []).length > 1
        ? `<div style="margin-top:5px;border-top:1px solid rgba(255,255,255,.15);padding-top:5px">🤝 together in <b>~${r.converge}h</b></div>` : '';
      const html = `<b>🤝 ${r.name}</b>${r.when_text ? `<br><span style="opacity:.6">${r.when_text}</span>` : ''}<div style="margin-top:6px;font-size:12px">${etaRows}${conv}</div>`;
      L.marker([r.lat, r.lng], { icon: L.divIcon({ className: 'rdv', html: '◆', iconSize: [22, 22] }) })
        .addTo(layers.rdv).bindPopup(html);
    }

    if (allPts.length) map.fitBounds(L.latLngBounds(allPts).pad(0.15));

    // Each legend chip toggles its layer on/off (click to hide a rig or the rendezvous).
    document.querySelectorAll('.legend .chip').forEach((chip) => {
      const key = chip.dataset.layer; const layer = layers[key];
      if (!layer) return;
      // Hide a chip that has nothing behind it (no brother trip / no rendezvous).
      const empty = (key === 'derek' && trips.length < 2) || (key === 'rdv' && !(data.rendezvous || []).length);
      if (empty) { chip.hidden = true; map.removeLayer(layer); return; }
      chip.addEventListener('click', () => {
        if (map.hasLayer(layer)) { map.removeLayer(layer); chip.classList.add('off'); }
        else { layer.addTo(map); chip.classList.remove('off'); }
      });
    });
  }
  const s = document.createElement('script');
  s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  s.onload = initMap;
  s.onerror = () => {};
  document.head.appendChild(s);
</script>

<style>
  /* isolate = own stacking context, so Leaflet's panes/controls (and their high
     z-indexes) stay contained and can't paint over the sticky header. This alone
     fixes the overlap WITHOUT touching Leaflet's internal pane layering. */
  .map-wrap { position: relative; z-index: 0; isolation: isolate; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .map { height: 440px; width: 100%; background: #0b1018; }
  .map-fallback { height: 100%; display: grid; place-content: center; text-align: center; gap: .3rem; padding: 2rem; }
  .map-fallback .big { font-size: 3rem; }
  .map-fallback code { font-family: var(--font-mono); color: var(--green); }
  .legend { display: flex; align-items: center; gap: .8rem; padding: .8rem 1rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .legend .chip { color: var(--c, var(--muted)); font-size: .82rem; font-weight: 600; background: none; border: 0; padding: .15rem .25rem; cursor: pointer; font-family: inherit; transition: opacity .15s; }
  .legend .chip:hover { opacity: .8; }
  .legend .chip.off { opacity: .3; text-decoration: line-through; }
  .legend-hint { margin-left: auto; font-size: .72rem; }
  :global(.rdv) { color: #fbbf24; font-size: 18px; line-height: 22px; text-align: center; text-shadow: 0 0 6px rgba(251,191,36,.8); }
  :global(.post-pin) { font-size: 18px; line-height: 24px; text-align: center; filter: drop-shadow(0 0 4px rgba(0,0,0,.6)); }
  /* Radar "you are here" ping. .live-pulse sits at the marker point (0×0 anchor);
     <i> expands + fades outward, <b> is the solid centre dot. */
  :global(.live-pulse) { position: relative; display: block; color: #34d399; }
  :global(.live-pulse i) { position: absolute; left: -8px; top: -8px; width: 16px; height: 16px; border-radius: 50%; background: currentColor; opacity: .5; animation: live-ping 2.2s ease-out infinite; }
  :global(.live-pulse b) { position: absolute; left: -6px; top: -6px; width: 12px; height: 12px; border-radius: 50%; background: currentColor; border: 2px solid #fff; box-sizing: border-box; box-shadow: 0 0 6px rgba(0,0,0,.55); }
  @keyframes live-ping { 0% { transform: scale(1); opacity: .5; } 70% { transform: scale(4); opacity: 0; } 100% { transform: scale(4); opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { :global(.live-pulse i) { animation: none; opacity: .22; } }
  :global(.leaflet-popup-content) { font-family: inherit; }
</style>
