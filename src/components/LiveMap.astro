---
// "Where's David" map — David by default; tap "See the brothers" to overlay
// Derek's route + position and the 🤝 rendezvous points (both at once). Loads
// Leaflet from CDN with a graceful offline fallback. Data from /api/trips.
// Geotagged journal posts (photo EXIF / live position) drop as 📷 pins.
import type { Post } from '../lib/types';
interface Props { posts?: Post[] }
const { posts = [] } = Astro.props;
const thumb320 = (u: string | undefined) => (u && u.startsWith('/img/')) ? `${u}?w=320` : (u ?? null);
const geoPosts = posts
  .filter((p) => typeof p.lat === 'number' && typeof p.lng === 'number' && p.published_at)
  .map((p) => ({ id: p.id, title: p.title, lat: p.lat, lng: p.lng, thumb: thumb320((p.media || []).find((m) => /\.(jpe?g|png|webp|gif|heic)/i.test(m))) }));
---
<div class="map-wrap" data-reveal>
  <script type="application/json" id="geo-posts" set:html={JSON.stringify(geoPosts)}></script>
  <div id="dtours-map" class="map">
    <div class="map-fallback">
      <span class="big">🛰️</span>
      <p>Live map loads here — David's route + current position from the inReach feed.</p>
      <p class="muted">Set <code>MAPSHARE_FEED_URL</code> for the live dot.</p>
    </div>
  </div>
  <div class="legend">
    <span class="chip" style="--c:#34d399">● David</span>
    <span class="chip bro" style="--c:#fb923c" hidden>● Derek</span>
    <span class="chip bro" style="--c:#fbbf24" hidden>◆ rendezvous</span>
    <button id="bros-toggle" class="bros-btn" hidden>🚐🚐 See the brothers</button>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script>
  async function initMap() {
    // @ts-ignore — Leaflet attaches to window
    const L = window.L; if (!L) return; // offline / CDN blocked → keep fallback
    const el = document.getElementById('dtours-map'); if (!el) return;
    el.innerHTML = '';
    const map = L.map(el, { scrollWheelZoom: false }).setView([44, -106], 4);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19,
    }).addTo(map);

    let data;
    try { data = await (await fetch('/api/trips')).json(); } catch { return; }
    const trips = data.trips || [];
    if (!trips.length) return;

    // Draw one trip's route + stops + current position onto a target layer.
    const drawTrip = (trip, target) => {
      const pts = [];
      L.polyline(trip.route, { color: trip.color, weight: 3, opacity: .75, dashArray: '6 7' }).addTo(target);
      for (const s of (trip.stops || [])) {
        L.circleMarker([s.lat, s.lng], { radius: 4, color: trip.color, fillColor: trip.color, fillOpacity: .9, weight: 1 })
          .addTo(target).bindPopup(`${s.emoji} ${s.name} <span style="opacity:.6">· ${trip.name}</span>`);
      }
      if (trip.position) {
        const p = trip.position;
        L.circleMarker([p.lat, p.lng], { radius: 9, color: '#fff', weight: 2, fillColor: trip.color, fillOpacity: 1 })
          .addTo(target).bindPopup(`<b>${trip.name}</b> · ${p.when}${p.live ? '' : ' <span style="opacity:.6">(approx)</span>'}`);
      }
      (trip.route || []).forEach((c) => pts.push(c));
      return pts;
    };

    // David (first trip) is always visible.
    const davidPts = drawTrip(trips[0], map);
    const davidBounds = L.latLngBounds(davidPts);
    map.fitBounds(davidBounds.pad(0.15));

    // 📷 Geotagged journal posts drop as pins (photo EXIF / live position).
    try {
      const posts = JSON.parse(document.getElementById('geo-posts')?.textContent || '[]');
      for (const p of posts) {
        const thumb = p.thumb ? `<img src="${p.thumb}" style="width:160px;border-radius:8px;display:block;margin-bottom:6px">` : '';
        L.marker([p.lat, p.lng], { icon: L.divIcon({ className: 'post-pin', html: '📷', iconSize: [24, 24] }) })
          .addTo(map).bindPopup(`${thumb}<b>${p.title}</b><br><a href="/journal/${p.id}">read →</a>`);
      }
    } catch {}

    // The brothers overlay (Derek + rendezvous) lives in a toggleable group.
    const others = L.layerGroup();
    const allPts = [...davidPts];
    for (const trip of trips.slice(1)) allPts.push(...drawTrip(trip, others));
    for (const r of (data.rendezvous || [])) {
      const etaRows = (r.etas || []).map((e) =>
        `<div style="display:flex;justify-content:space-between;gap:12px"><span style="color:${e.color}">●&nbsp;${e.name}</span><span>~${e.hours}h${e.live ? '' : ' <i style="opacity:.5">approx</i>'}</span></div>`).join('');
      const conv = r.converge != null && (r.etas || []).length > 1
        ? `<div style="margin-top:5px;border-top:1px solid rgba(255,255,255,.15);padding-top:5px">🤝 together in <b>~${r.converge}h</b></div>` : '';
      const html = `<b>🤝 ${r.name}</b>${r.when_text ? `<br><span style="opacity:.6">${r.when_text}</span>` : ''}<div style="margin-top:6px;font-size:12px">${etaRows}${conv}</div>`;
      L.marker([r.lat, r.lng], { icon: L.divIcon({ className: 'rdv', html: '◆', iconSize: [22, 22] }) })
        .addTo(others).bindPopup(html);
    }
    const allBounds = L.latLngBounds(allPts);

    // Wire the toggle (only if there's actually a brother to show).
    const btn = document.getElementById('bros-toggle');
    const broChips = [...document.querySelectorAll('.legend .chip.bro')];
    if (btn && trips.length > 1) {
      btn.hidden = false;
      let shown = false;
      btn.addEventListener('click', () => {
        shown = !shown;
        if (shown) { others.addTo(map); map.fitBounds(allBounds.pad(0.15)); btn.textContent = '🚐 Just David'; }
        else { map.removeLayer(others); map.fitBounds(davidBounds.pad(0.15)); btn.textContent = '🚐🚐 See the brothers'; }
        broChips.forEach((c) => (c.hidden = !shown));
      });
    }
  }
  const s = document.createElement('script');
  s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  s.onload = initMap;
  s.onerror = () => {};
  document.head.appendChild(s);
</script>

<style>
  /* isolate = own stacking context, so Leaflet's panes/controls (and their high
     z-indexes) stay contained and can't paint over the sticky header. This alone
     fixes the overlap WITHOUT touching Leaflet's internal pane layering. */
  .map-wrap { position: relative; z-index: 0; isolation: isolate; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .map { height: 440px; width: 100%; background: #0b1018; }
  .map-fallback { height: 100%; display: grid; place-content: center; text-align: center; gap: .3rem; padding: 2rem; }
  .map-fallback .big { font-size: 3rem; }
  .map-fallback code { font-family: var(--font-mono); color: var(--green); }
  .legend { display: flex; align-items: center; gap: .8rem; padding: .8rem 1rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .legend .chip { color: var(--c, var(--muted)); font-size: .82rem; font-weight: 600; }
  .bros-btn { margin-left: auto; background: rgba(251,146,60,.12); border: 1px solid rgba(251,146,60,.4); color: #fb923c; font-weight: 700; font-size: .82rem; padding: .4rem .8rem; border-radius: 999px; cursor: pointer; }
  .bros-btn:hover { background: rgba(251,146,60,.2); }
  :global(.rdv) { color: #fbbf24; font-size: 18px; line-height: 22px; text-align: center; text-shadow: 0 0 6px rgba(251,191,36,.8); }
  :global(.post-pin) { font-size: 18px; line-height: 24px; text-align: center; filter: drop-shadow(0 0 4px rgba(0,0,0,.6)); }
  :global(.leaflet-popup-content) { font-family: inherit; }
</style>
