---
// "Where's everyone" map. Loads Leaflet from CDN (graceful fallback if offline).
// Draws every registered trip's route + current position from /api/trips, and
// marks the rendezvous points where two routes meet — David & Derek in relation.
---
<div class="map-wrap" data-reveal>
  <div id="dtours-map" class="map">
    <div class="map-fallback">
      <span class="big">🛰️</span>
      <p>Live map loads here — routes + current positions for everyone on the road.</p>
      <p class="muted">Set <code>MAPSHARE_FEED_URL</code> for the live inReach dot.</p>
    </div>
  </div>
  <div class="legend">
    <span class="chip" style="--c:#34d399">● David</span>
    <span class="chip" style="--c:#fb923c">● Derek</span>
    <span class="chip" style="--c:#fbbf24">◆ rendezvous</span>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script>
  async function initMap() {
    // @ts-ignore — Leaflet attaches to window
    const L = window.L; if (!L) return; // offline / CDN blocked → keep fallback
    const el = document.getElementById('dtours-map'); if (!el) return;
    el.innerHTML = '';
    const map = L.map(el, { scrollWheelZoom: false }).setView([44, -106], 4);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19,
    }).addTo(map);

    let data;
    try { data = await (await fetch('/api/trips')).json(); } catch { return; }
    const all = [];

    for (const trip of (data.trips || [])) {
      if (!trip.route?.length) continue;
      // planned route
      L.polyline(trip.route, { color: trip.color, weight: 3, opacity: .75, dashArray: '6 7' }).addTo(map);
      // stop dots
      for (const s of (trip.stops || [])) {
        L.circleMarker([s.lat, s.lng], { radius: 4, color: trip.color, fillColor: trip.color, fillOpacity: .9, weight: 1 })
          .addTo(map).bindPopup(`${s.emoji} ${s.name} <span style="opacity:.6">· ${trip.name}</span>`);
      }
      // current position (bigger, pulsing-style ring)
      if (trip.position) {
        const p = trip.position;
        L.circleMarker([p.lat, p.lng], { radius: 9, color: '#fff', weight: 2, fillColor: trip.color, fillOpacity: 1 })
          .addTo(map)
          .bindPopup(`<b>${trip.name}</b> · ${p.when}${p.live ? '' : ' <span style="opacity:.6">(approx — set MapShare feed)</span>'}`);
      }
      trip.route.forEach((c) => all.push(c));
    }

    // rendezvous diamonds
    for (const r of (data.rendezvous || [])) {
      L.marker([r.lat, r.lng], {
        icon: L.divIcon({ className: 'rdv', html: '◆', iconSize: [22, 22] }),
      }).addTo(map).bindPopup(`<b>🤝 Rendezvous</b> · ${r.name}`);
    }

    if (all.length) map.fitBounds(L.latLngBounds(all).pad(0.15));
  }
  const s = document.createElement('script');
  s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  s.onload = initMap;
  s.onerror = () => {};
  document.head.appendChild(s);
</script>

<style>
  /* position+z-index establishes a stacking context so Leaflet's internal panes
     (z-index 400–700) and controls can't paint above the sticky site header. */
  .map-wrap { position: relative; z-index: 0; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .map { height: 440px; width: 100%; background: #0b1018; }
  .map-fallback { height: 100%; display: grid; place-content: center; text-align: center; gap: .3rem; padding: 2rem; }
  .map-fallback .big { font-size: 3rem; }
  .map-fallback code { font-family: var(--font-mono); color: var(--green); }
  .legend { display: flex; gap: .8rem; padding: .8rem 1rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .legend .chip { color: var(--c, var(--muted)); font-size: .82rem; font-weight: 600; }
  :global(.rdv) { color: #fbbf24; font-size: 18px; line-height: 22px; text-align: center; text-shadow: 0 0 6px rgba(251,191,36,.8); }
  :global(.leaflet-popup-content) { font-family: inherit; }
</style>
