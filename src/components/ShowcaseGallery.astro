---
// Editorial hover-reveal gallery (Montoya/Manifesto homage) for trip media.
// Uses your own photos; tiles show a gradient placeholder until media exists.
import type { Post } from '../lib/types';
interface Props { posts: Post[]; }
const { posts } = Astro.props;
const tiles = posts.slice(0, 6);
---
<div class="gallery">
  {tiles.map((p, i) => (
    <a class:list={['tile', { wide: i % 5 === 0 }]} href={`/journal#${p.id}`} data-reveal>
      {p.media[0]
        ? <img src={p.media[0]} alt={p.title} loading="lazy" />
        : <div class="ph" style={`--h:${(i * 57) % 360}`}></div>}
      <div class="overlay">
        <div class="o-title">{p.title}</div>
        <div class="o-meta mono">{p.published_at ? new Date(p.published_at).toLocaleDateString() : 'queued · Tier 1'}</div>
      </div>
    </a>
  ))}
</div>

<style>
  .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  @media (max-width: 760px) { .gallery { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .gallery { grid-template-columns: 1fr; } }
  .tile { position: relative; aspect-ratio: 4/3; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); display: block; }
  .tile.wide { grid-column: span 2; }
  @media (max-width: 760px) { .tile.wide { grid-column: span 2; } }
  @media (max-width: 460px) { .tile.wide { grid-column: span 1; } }
  .tile img, .tile .ph { width: 100%; height: 100%; object-fit: cover; transition: transform .6s var(--ease); display: block; }
  .ph { background: linear-gradient(140deg, hsl(var(--h) 30% 18%), hsl(calc(var(--h) + 40) 35% 10%)); }
  .tile:hover img, .tile:hover .ph { transform: scale(1.06); }
  .overlay { position: absolute; inset: auto 0 0 0; padding: 1rem; background: linear-gradient(0deg, rgba(0,0,0,.78), transparent); transform: translateY(8px); opacity: .85; transition: all .4s var(--ease); }
  .tile:hover .overlay { transform: none; opacity: 1; }
  .o-title { font-weight: 700; }
  .o-meta { font-size: .72rem; color: var(--green-2); }
</style>
