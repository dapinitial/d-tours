---
// "Reach the crew" — iMessage (Apple) or email. Per-trip contact when the caller passes
// email/phone; with NO props it falls back to David's split-assembled contact (kept out
// of static HTML for scrapers) — that's the global footer + home showcase. A trip that
// passed props but set no contact renders nothing (we never show David's on their page).
interface Props { compact?: boolean; email?: string | null; phone?: string | null }
const { compact = false, email, phone } = Astro.props;
const noProps = email === undefined && phone === undefined;     // caller = footer/home → David fallback
const e = (email ?? '').trim();
const p = (phone ?? '').replace(/[^\d]/g, '');
const showAtAll = noProps || !!e || !!p;
---
{showAtAll && (
  <div class:list={['reach', { compact }]} data-email={e} data-phone={p} data-fallback={noProps ? '1' : ''}>
    <span class="reach-label">📲 Reach the crew</span>
    <div class="reach-btns">
      <a class="rb apple-only" data-kind="imessage" href="#" aria-label="iMessage">💬 iMessage</a>
      <a class="rb" data-kind="email" href="#" aria-label="Email">📧 Email</a>
    </div>
  </div>
)}

<script>
  document.querySelectorAll('.reach').forEach((root) => {
    const fb = root.dataset.fallback === '1';
    // Per-tenant contact from data-attrs; else (footer/home) David's parts, assembled here.
    const mail = root.dataset.email || (fb ? ['me', 'davidpuerto.com'].join('@') : '');
    const num = (root.dataset.phone || (fb ? ['1', '206', '397', '9040'].join('') : '')).replace(/[^\d]/g, '');
    const hrefs: Record<string, string> = {
      imessage: num ? `imessage://+${num}` : '',
      email: mail ? `mailto:${mail}` : '',
    };
    root.querySelectorAll<HTMLAnchorElement>('.rb').forEach((a) => {
      const k = a.dataset.kind; const href = k ? hrefs[k] : '';
      if (href) a.href = href; else a.remove();
    });
    const ua = navigator.userAgent;
    const isApple = /iPhone|iPad|iPod|Macintosh/i.test(ua)
      || (navigator.platform === 'MacIntel' && (navigator.maxTouchPoints ?? 0) > 1);
    if (isApple) root.classList.add('is-apple');
  });
</script>

<style>
  .reach { display: flex; align-items: center; gap: .8rem; flex-wrap: wrap; }
  .reach-label { font-weight: 700; font-size: .9rem; }
  .reach.compact .reach-label { font-size: .82rem; color: var(--muted); }
  .reach-btns { display: flex; gap: .5rem; flex-wrap: wrap; }
  .rb { display: inline-flex; align-items: center; font-size: .85rem; font-weight: 600; padding: .4rem .8rem;
        border-radius: 999px; border: 1px solid var(--border-2); color: var(--text); text-decoration: none; transition: all .15s; }
  .rb:hover { border-color: var(--green); color: var(--green); }
  /* iMessage hidden by default (non-Apple / no-JS); revealed on Apple devices. */
  .apple-only { display: none; }
  .reach.is-apple .apple-only { display: inline-flex; }
</style>
