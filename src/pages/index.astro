---
import Base from '../layouts/Base.astro';
import Timeline from '../components/Timeline.astro';
import ObjectivesTable from '../components/ObjectivesTable.astro';
import ShotgunCard from '../components/ShotgunCard.astro';
import LiveMap from '../components/LiveMap.astro';
import CareLayers from '../components/CareLayers.astro';
import ShowcaseGallery from '../components/ShowcaseGallery.astro';
import CheerSquad from '../components/CheerSquad.astro';
import TryItWidget from '../components/TryItWidget.astro';
import ShotgunChat from '../components/ShotgunChat.astro';
import ShareButton from '../components/ShareButton.astro';
import ReachUs from '../components/ReachUs.astro';
import SquadStrip from '../components/SquadStrip.astro';
import { getStops, getObjectives, getProposedObjectives, getResources, getPosts, getDetours, getPlaylists, getCompanions } from '../lib/data';

const [stops, objectives, proposedObjectives, resources, posts, detours, playlists, companions] = await Promise.all([
  getStops(), getObjectives(), getProposedObjectives(), getResources(), getPosts({ publishedOnly: true }), getDetours(), getPlaylists(), getCompanions(),
]);
// Share card uses the latest real trip photo when one exists (storage URLs are absolute).
const shareImg = posts.flatMap((p) => p.media ?? [])
  .find((m) => /\.(jpe?g|png|webp|gif|avif)(\?|$)/i.test(m) || m.includes('/storage/v1/object/public/media/'));
const venmoUrl = import.meta.env.PUBLIC_VENMO_URL ?? '';
---
<Base
  title="D-Tours · Austin → Squamish, Summer 2026"
  description="Follow a 3-month climbing road trip riding shotgun with an AI co-pilot — live detours, the trip mixtape, and the journal from the road."
  image={shareImg}
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow" data-reveal>Austin → Squamish · Summer 2026</p>
      <h1 data-reveal>THE ROAD&nbsp;TRIP<br/><span class="accent">MEGA&#8209;LOOP</span></h1>
      <p class="lede" data-reveal>
        An AI travel companion riding shotgun — tracking deadlines, surfacing weird-and-wonderful
        detours that fit the time you have, and getting you to every rendezvous on schedule.
      </p>
      <div class="cta" data-reveal>
        <a href="/journal" class="btn">Follow the journey</a>
        <a href="#live" class="btn ghost">🛰️ Where's David?</a>
        <a href="/plan" class="btn ghost">📄 Trip plan</a>
      </div>
      <div class="hero-actions" data-reveal>
        <ShareButton path="/" label="📲 Share" text="Follow our Austin → Squamish climbing road trip 🚐🧗 — track where we are and meet up along the way:" />
        <a class="ha" href="#cheer">📬 Dispatch</a>
        {venmoUrl && <a class="ha venmo" href={venmoUrl} target="_blank" rel="noopener">💸 Fuel the trip</a>}
        <ReachUs compact />
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🗺️ The Route</p>
        <h2>Eleven stops, one hard deadline</h2>
        <p>Ricardo's wedding (Aug 1) is the fixed wall everything bends around. Everything in green has slack — that's where the detours live.</p>
      </div>
      <Timeline stops={stops} objectives={objectives} />
    </div>
  </section>

  <!-- LIVE MAP -->
  <section class="alt" id="live">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🛰️ Live</p>
        <h2>Where's David right now?</h2>
        <p>inReach satellite breadcrumbs polled from MapShare — the dot stays live off-grid even with the Starlink dish stowed. Tap <strong>🚐🚐 See the brothers</strong> to overlay Derek's route and the 🤝 rendezvous where they meet.</p>
      </div>
      <LiveMap posts={posts} />
    </div>
  </section>

  <SquadStrip crew={companions} />

  <!-- MEET SHOTGUN — the companion + live demo (combined) -->
  <section id="shotgun">
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow">📡 Your Companion</p>
        <h2>Meet Shotgun</h2>
        <p>The AI riding shotgun: it watches the Aug 1 deadline, scouts weird-and-wonderful detours that fit the slack you have, and pings you on whatever can reach you — iMessage or email. Here's what a transmission sounds like:</p>
      </div>
      <ShotgunCard detours={detours} />
      <div class="try-lead" style="margin-top: 2rem;">
        <p class="eyebrow">💬 …or just talk to it</p>
        <p class="muted">Ask Shotgun anything — a climb, the route, swapping an objective, or whether we'll make the wedding.</p>
      </div>
      <ShotgunChat />
      <div class="try-lead" style="margin-top: 2rem;">
        <p class="eyebrow">✨ Now try it — no signup</p>
        <p class="muted">Tap a spot (or use your location) and watch the live engine scout real detours near <em>you</em>.</p>
      </div>
      <TryItWidget />
    </div>
  </section>

  <!-- OBJECTIVES -->
  <section class="alt" id="objectives">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🧗 The Objectives</p>
        <h2>Climbing beta</h2>
        <p>The headline sends — tap any for Shotgun's full dossier: routes, rack, GPX, camp, permits, conditions.</p>
      </div>
      <ObjectivesTable objectives={objectives} />
      <p class="cond-link"><a href="/conditions">🌡️ See route conditions — weather, fire/smoke & avalanche across every objective →</a></p>

      {proposedObjectives.length > 0 && (
        <div class="considering" data-reveal>
          <h3>🧭 Help us decide — climbs we're weighing</h3>
          <p class="muted">Might swap one of these in depending on how we're feeling. <strong>Tap one, read the beta, and tell us what to send</strong> (drop a comment)!</p>
          <div class="cons-list" id="cons-list">
            {proposedObjectives.map((o) => (
              <a class="cons" href={`/objectives/${o.id}`} data-oid={o.id}>
                <span class="cons-name">🧗 {o.name}</span>
                <span class="cons-meta mono">{o.grade} · {o.region}</span>
                <span class="cons-dist"></span>
                {o.note && <span class="cons-note muted">{o.note}</span>}
              </a>
            ))}
          </div>
        </div>
      )}

      <script>
        // Location-aware: annotate each proposed climb with drive-time from where we are now.
        (() => {
          const cards = [...document.querySelectorAll<HTMLElement>('.cons[data-oid]')];
          if (!cards.length) return;
          fetch('/api/mapshare').then((r) => r.json()).then((pos) => {
            if (!pos || typeof pos.lat !== 'number') return;
            return fetch(`/api/nearby?lat=${pos.lat}&lng=${pos.lng}`).then((r) => r.json()).then((d) => {
              const byId: Record<string, any> = Object.fromEntries((d.all || []).map((x: any) => [x.id, x]));
              cards.forEach((c) => {
                const n = byId[c.dataset.oid!];
                const dist = c.querySelector('.cons-dist');
                if (n && dist) {
                  dist.textContent = `🛰️ ~${n.drive_hours}h away (${n.miles} mi)` + (n.within ? ' · in range!' : '');
                  if (n.within) c.classList.add('near-now');
                }
              });
              const list = document.getElementById('cons-list');
              if (list) cards.sort((a, b) => (byId[a.dataset.oid!]?.miles ?? 1e9) - (byId[b.dataset.oid!]?.miles ?? 1e9)).forEach((c) => list.appendChild(c));
            });
          }).catch(() => {});
        })();
      </script>
    </div>
  </section>

  <!-- CARE LAYERS -->
  <section>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🤝 The Four Layers</p>
        <h2>Shotgun's got your back</h2>
        <p>Not just a map — a companion watching four things at once so weeks in the car keep you healthy, clean, and stoked.</p>
      </div>
      <CareLayers resources={resources} />
    </div>
  </section>

  <!-- GALLERY -->
  <section class="alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">📸 From the Road</p>
        <h2>Latest dispatches</h2>
        <p>Your own photos, published as you go (and enhanced with AI later, if visitors pitch in their keys).</p>
      </div>
      <ShowcaseGallery posts={posts} />
    </div>
  </section>

  <!-- CHEER SQUAD -->
  <section id="cheer">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🎉 Cheer Squad</p>
        <h2>Roll with us</h2>
        <p>Fuel the trip, get the dispatch, send me a detour, or pick the soundtrack. The road's better with a crew.</p>
      </div>
      <CheerSquad playlists={playlists} />
    </div>
  </section>
</Base>

<style>
  .hero { padding: clamp(4rem, 12vw, 9rem) 0 clamp(3rem, 7vw, 6rem); }
  .hero h1 { margin: 0 0 1.3rem; }
  .hero .accent { color: var(--green); }
  .lede { max-width: 620px; font-size: clamp(1.05rem, 2vw, 1.3rem); color: var(--muted); }
  .cta { display: flex; gap: .8rem; margin-top: 2rem; flex-wrap: wrap; }
  .hero-actions { display: flex; gap: .7rem; margin-top: 1.1rem; flex-wrap: wrap; align-items: center; }
  .ha { font-size: .85rem; font-weight: 600; padding: .4rem .8rem; border-radius: 999px; border: 1px solid var(--border-2); color: var(--text); text-decoration: none; transition: all .15s; }
  .ha:hover { border-color: var(--green); color: var(--green); }
  .ha.venmo:hover { border-color: var(--sky); color: var(--sky); }
  section.alt { background: linear-gradient(180deg, transparent, rgba(255,255,255,.012), transparent); }
  .container.narrow { width: min(100% - 2.5rem, 760px); }
  .considering { margin-top: 1.6rem; padding: 1.2rem; border: 1px solid rgba(56,189,248,.3); border-radius: var(--radius); background: linear-gradient(180deg, rgba(56,189,248,.07), transparent); }
  .considering h3 { margin: 0 0 .3rem; }
  .cons-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: .7rem; margin-top: .9rem; }
  .cons { display: grid; gap: .25rem; padding: .8rem .9rem; background: var(--panel); border: 1px solid var(--border); border-radius: 10px; text-decoration: none; transition: border-color .15s; }
  .cons:hover { border-color: var(--sky); }
  .cons-name { font-weight: 700; color: var(--text); }
  .cons-meta { font-size: .76rem; color: var(--green); }
  .cons-note { font-size: .82rem; line-height: 1.4; }
  .cons-dist { font-size: .76rem; color: var(--sky); font-weight: 600; }
  .cons-dist:empty { display: none; }
  .cons.near-now { border-color: var(--green); box-shadow: 0 0 0 2px rgba(52,211,153,.18); }
  .cons.near-now .cons-dist { color: var(--green); }
</style>
