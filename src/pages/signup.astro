---
import Base from '../layouts/Base.astro';
---
<Base title="D-Tours · Start your trip">
  <section>
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow">🚪 Start your own trip</p>
        <h2>Plan your adventure</h2>
        <p>Climbing, a World Cup run, a road trip — whatever you're chasing. Enter your email and we'll send a magic link. No passwords.</p>
      </div>
      <form id="signup-form" class="card login-card">
        <input type="email" id="email" placeholder="you@email.com" required autocomplete="email" inputmode="email" />
        <button class="btn" type="submit">Send magic link</button>
        <p class="msg" id="msg"></p>
        <p class="alt">Already have a trip? <a href="/login">Sign in</a></p>
      </form>
    </div>
  </section>

  <script>
    import { createBrowserClient } from '@supabase/ssr';
    const url = import.meta.env.PUBLIC_SUPABASE_URL;
    const key = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ?? import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const form = document.getElementById('signup-form');
    const msg = document.getElementById('msg');
    if (url && key && form) {
      const sb = createBrowserClient(url, key);
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('email')).value.trim();
        msg.textContent = 'Sending…'; msg.className = 'msg';
        // Redirect back to THIS origin's /auth/callback (keeps the PKCE verifier on the
        // same host that started the flow). Must be in Supabase's Redirect URLs allow-list.
        const { error } = await sb.auth.signInWithOtp({
          email,
          options: { emailRedirectTo: location.origin + '/auth/callback', shouldCreateUser: true },
        });
        if (error) { msg.textContent = error.message; msg.className = 'msg err'; }
        else { msg.textContent = '✅ Check your email for the magic link!'; msg.className = 'msg ok'; }
      });
    } else if (msg) {
      msg.textContent = 'Auth not configured yet (no Supabase keys).'; msg.className = 'msg err';
    }
  </script>

  <style>
    .container.narrow { width: min(100% - 2.5rem, 520px); }
    .login-card { display: grid; gap: .8rem; }
    .login-card input { width: 100%; background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .8rem .9rem; font: inherit; min-height: 46px; }
    .msg { margin: 0; min-height: 1.2em; font-size: .9rem; }
    .msg.ok { color: var(--green); } .msg.err { color: var(--red); }
    .alt { margin: .2rem 0 0; font-size: .85rem; color: var(--muted); }
  </style>
</Base>
