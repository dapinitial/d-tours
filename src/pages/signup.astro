---
import Base from '../layouts/Base.astro';
---
<Base title="D-Tours · Start your trip">
  <section>
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow">🚪 Start your own trip</p>
        <h2>Plan your adventure</h2>
        <p>Climbing, a World Cup run, a road trip — whatever you're chasing. Enter your email and we'll send a 6-digit code. No passwords.</p>
      </div>

      <form id="email-form" class="card login-card">
        <input type="email" id="email" placeholder="you@email.com" required autocomplete="email" inputmode="email" />
        <button class="btn" type="submit">Send code</button>
        <p class="msg" id="msg"></p>
        <p class="alt">Already have a trip? <a href="/login">Sign in</a></p>
      </form>

      <form id="code-form" class="card login-card" hidden>
        <p class="sent">Enter the 6-digit code we emailed to <strong id="sent-to"></strong>.</p>
        <input type="text" id="code" placeholder="Code from your email" inputmode="numeric" autocomplete="one-time-code" maxlength="12" />
        <button class="btn" type="submit">Verify & create my trip →</button>
        <p class="msg" id="msg2"></p>
        <p class="alt"><a href="#" id="resend">Resend code</a> · <a href="#" id="change">Use a different email</a></p>
      </form>
    </div>
  </section>

  <script>
    import { createBrowserClient } from '@supabase/ssr';
    const url = import.meta.env.PUBLIC_SUPABASE_URL;
    const key = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ?? import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const emailForm = document.getElementById('email-form');
    const codeForm = document.getElementById('code-form');
    const msg = document.getElementById('msg');
    const msg2 = document.getElementById('msg2');
    let email = '';

    if (url && key && emailForm) {
      const sb = createBrowserClient(url, key);
      const sendCode = async () => {
        // shouldCreateUser: true → makes the account on first code request.
        const { error } = await sb.auth.signInWithOtp({ email, options: { shouldCreateUser: true } });
        return error;
      };
      emailForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        email = (document.getElementById('email')).value.trim();
        msg.textContent = 'Sending…'; msg.className = 'msg';
        const err = await sendCode();
        if (err) { msg.textContent = err.message; msg.className = 'msg err'; return; }
        document.getElementById('sent-to').textContent = email;
        emailForm.hidden = true; codeForm.hidden = false;
        document.getElementById('code').focus();
      });
      codeForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const token = (document.getElementById('code')).value.trim();
        msg2.textContent = 'Verifying…'; msg2.className = 'msg';
        const { error } = await sb.auth.verifyOtp({ email, token, type: 'email' });
        if (error) { msg2.textContent = 'That code didn’t work — double-check it or resend.'; msg2.className = 'msg err'; return; }
        try { await sb.rpc('link_my_crew'); } catch {}
        msg2.textContent = '✅ You’re in! Setting up your trip…'; msg2.className = 'msg ok';
        window.location.href = '/cms'; // middleware routes a brand-new user to onboarding
      });
      document.getElementById('resend').addEventListener('click', async (e) => {
        e.preventDefault(); msg2.textContent = 'Sending a new code…'; msg2.className = 'msg';
        const err = await sendCode();
        msg2.textContent = err ? err.message : '📧 New code sent.'; msg2.className = err ? 'msg err' : 'msg ok';
      });
      document.getElementById('change').addEventListener('click', (e) => {
        e.preventDefault(); codeForm.hidden = true; emailForm.hidden = false; msg.textContent = ''; msg2.textContent = '';
      });
    } else if (msg) {
      msg.textContent = 'Auth not configured yet (no Supabase keys).'; msg.className = 'msg err';
    }
  </script>

  <style>
    .container.narrow { width: min(100% - 2.5rem, 520px); }
    .login-card { display: grid; gap: .8rem; }
    .login-card input { width: 100%; background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .8rem .9rem; font: inherit; min-height: 46px; }
    #code { letter-spacing: .12em; font-size: 1.15rem; text-align: center; font-weight: 600; }
    .sent { margin: 0; font-size: .92rem; color: var(--muted); }
    .msg { margin: 0; min-height: 1.2em; font-size: .9rem; }
    .msg.ok { color: var(--green); } .msg.err { color: var(--red); }
    .alt { margin: .2rem 0 0; font-size: .85rem; color: var(--muted); }
  </style>
</Base>
