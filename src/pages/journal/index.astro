---
import Base from '../../layouts/Base.astro';
import { getPosts } from '../../lib/data';
const posts = await getPosts();

// Classify a media URL so we can render photos inline and video as an embed.
function media(url: string): { type: 'image' | 'youtube' | 'vimeo' | 'link'; embed?: string } {
  if (/\.(jpe?g|png|webp|gif|heic|avif)(\?|$)/i.test(url) || url.includes('/storage/v1/object/public/media/')) {
    return { type: 'image' };
  }
  const yt = url.match(/(?:youtube\.com\/.*[?&]v=|youtu\.be\/|youtube\.com\/shorts\/)([\w-]{11})/);
  if (yt) return { type: 'youtube', embed: `https://www.youtube.com/embed/${yt[1]}` };
  const vm = url.match(/vimeo\.com\/(\d+)/);
  if (vm) return { type: 'vimeo', embed: `https://player.vimeo.com/video/${vm[1]}` };
  return { type: 'link' };
}
const shareImg = posts.flatMap((p) => p.media ?? []).find((m) => media(m).type === 'image');
---
<Base
  title="D-Tours · The Journal"
  description="Dispatches from the road — photos, video, and stories from the Austin → Squamish climbing loop."
  image={shareImg}
>
  <section>
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow">📓 The Journal</p>
        <h2>Dispatches from the loop</h2>
        <p>Posts publish when there's signal. Queued ones flush the moment the Starlink dish goes up at the rig.</p>
      </div>

      <div class="feed">
        {posts.map((p) => (
          <article id={p.id} class="post" data-reveal>
            <div class="p-head">
              <h3><a href={`/journal/${p.id}`}>{p.title}</a></h3>
              {p.published_at
                ? <span class="chip">{new Date(p.published_at).toLocaleDateString()}</span>
                : <span class="chip amber">queued</span>}
            </div>
            {p.body && <p class="p-body">{p.body}</p>}

            {p.media && p.media.length > 0 && (
              <div class={`gallery n${Math.min(p.media.length, 4)}`}>
                {p.media.map((url) => {
                  const m = media(url);
                  if (m.type === 'image') return <a class="shot" href={url} target="_blank" rel="noopener"><img src={url} loading="lazy" alt="" /></a>;
                  if (m.embed) return <div class="video"><iframe src={m.embed} loading="lazy" allow="accelerometer; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>;
                  return <a class="medialink" href={url} target="_blank" rel="noopener">▶ Watch →</a>;
                })}
              </div>
            )}

            <div class="p-foot">
              {(p.lat && p.lng) && <span class="mono muted">📍 {p.lat.toFixed(2)}, {p.lng.toFixed(2)}</span>}
              <button class="like" data-post={p.id}>🤘 <span class="count">{p.like_count ?? 0}</span></button>
            </div>
          </article>
        ))}
      </div>

      <div class="comment-note card">
        <h3>💬 Comments are crew-only</h3>
        <p class="muted">Likes are open to everyone. Written comments are reserved for invited friends &amp; family — coming soon.</p>
      </div>
    </div>
  </section>
</Base>

<script>
  // optimistic like; POSTs to /api/like (no-op success in mock mode)
  document.querySelectorAll('.like').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const span = btn.querySelector('.count');
      span.textContent = String(Number(span.textContent) + 1);
      btn.setAttribute('disabled', 'true');
      try { await fetch('/api/like', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ post: btn.dataset.post }) }); } catch {}
    });
  });
</script>

<style>
  .container.narrow { width: min(100% - 2.5rem, 760px); }
  .feed { display: grid; gap: 1.1rem; }
  .post { background: linear-gradient(180deg, var(--panel), var(--panel-2)); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.4rem; }
  .p-head { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: .6rem; }
  .p-head h3 { margin: 0; }
  .p-head h3 a { color: inherit; text-decoration: none; }
  .p-head h3 a:hover { color: var(--green); }
  .p-body { color: var(--muted); margin: 0; }
  .gallery { display: grid; gap: .4rem; margin-top: .9rem; border-radius: 12px; overflow: hidden; }
  .gallery.n2, .gallery.n4 { grid-template-columns: 1fr 1fr; }
  .gallery.n3 { grid-template-columns: 1fr 1fr; }
  .gallery.n3 .shot:first-child, .gallery.n3 .video:first-child { grid-column: 1 / -1; }
  .shot { display: block; }
  .shot img { width: 100%; height: 100%; max-height: 460px; object-fit: cover; display: block; transition: transform .3s var(--ease); }
  .shot:hover img { transform: scale(1.02); }
  .gallery.n1 .shot img { max-height: 560px; }
  .video { grid-column: 1 / -1; position: relative; aspect-ratio: 16 / 9; }
  .video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: 12px; }
  .medialink { grid-column: 1 / -1; padding: .8rem; text-align: center; background: rgba(255,255,255,.04); border: 1px solid var(--border); border-radius: 10px; color: var(--green); font-weight: 700; }
  .p-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; }
  .like { background: rgba(255,255,255,.04); border: 1px solid var(--border-2); color: var(--text); padding: .4rem .8rem; border-radius: 999px; cursor: pointer; transition: all .2s var(--ease); }
  .like:hover:not([disabled]) { border-color: var(--green); color: var(--green); }
  .like[disabled] { opacity: .6; cursor: default; }
  .comment-note { margin-top: 2rem; }
</style>
