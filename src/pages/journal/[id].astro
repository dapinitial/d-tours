---
import Base from '../../layouts/Base.astro';
import ShareButton from '../../components/ShareButton.astro';
import { getPost } from '../../lib/data';

export const prerender = false;

const { id } = Astro.params;
const post = id ? await getPost(id) : null;
if (!post) return Astro.redirect('/journal');

function media(url: string): { type: 'image' | 'youtube' | 'vimeo' | 'link'; embed?: string } {
  if (/\.(jpe?g|png|webp|gif|heic|avif)(\?|$)/i.test(url) || url.includes('/storage/v1/object/public/media/')) return { type: 'image' };
  const yt = url.match(/(?:youtube\.com\/.*[?&]v=|youtu\.be\/|youtube\.com\/shorts\/)([\w-]{11})/);
  if (yt) return { type: 'youtube', embed: `https://www.youtube.com/embed/${yt[1]}` };
  const vm = url.match(/vimeo\.com\/(\d+)/);
  if (vm) return { type: 'vimeo', embed: `https://player.vimeo.com/video/${vm[1]}` };
  return { type: 'link' };
}
const shareImg = (post.media ?? []).find((m) => media(m).type === 'image');
const desc = (post.body || 'A dispatch from the Austin → Squamish road trip.').slice(0, 180);
---
<Base title={`${post.title} · D-Tours`} description={desc} image={shareImg}>
  <section>
    <div class="container narrow">
      <a href="/journal" class="muted back">← all dispatches</a>
      <article class="post">
        <div class="p-head">
          <h1>{post.title}</h1>
          {post.published_at && <span class="chip">{new Date(post.published_at).toLocaleDateString()}</span>}
        </div>
        {post.body && <p class="p-body">{post.body}</p>}

        {post.media && post.media.length > 0 && (
          <div class="gallery">
            {post.media.map((url) => {
              const m = media(url);
              if (m.type === 'image') return <a class="shot" href={url} target="_blank" rel="noopener"><img src={url} loading="lazy" alt={post.title} /></a>;
              if (m.embed) return <div class="video"><iframe src={m.embed} loading="lazy" allow="accelerometer; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>;
              return <a class="medialink" href={url} target="_blank" rel="noopener">▶ Watch →</a>;
            })}
          </div>
        )}

        <div class="p-foot">
          {(post.lat && post.lng) && <span class="mono muted">📍 {post.lat.toFixed(2)}, {post.lng.toFixed(2)}</span>}
          <button class="like" data-post={post.id}>🤘 <span class="count">{post.like_count ?? 0}</span></button>
        </div>
      </article>
      <div class="share-row">
        <ShareButton path={`/journal/${post.id}`} label="📲 Share this dispatch" text={`From the road — "${post.title}":`} />
      </div>
    </div>
  </section>

  <script>
    document.querySelector('.like')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const span = btn.querySelector('.count'); span.textContent = String(Number(span.textContent) + 1);
      btn.setAttribute('disabled', 'true');
      try { await fetch('/api/like', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ post: btn.dataset.post }) }); } catch {}
    });
  </script>

  <style>
    .container.narrow { width: min(100% - 2.5rem, 760px); }
    .back { display: inline-block; margin-bottom: 1rem; font-size: .9rem; }
    .post { background: linear-gradient(180deg, var(--panel), var(--panel-2)); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.6rem; }
    .p-head { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: .6rem; }
    .p-head h1 { margin: 0; font-size: 1.6rem; }
    .p-body { color: var(--muted); margin: 0; line-height: 1.6; white-space: pre-wrap; }
    .gallery { display: grid; gap: .5rem; margin-top: 1rem; border-radius: 12px; overflow: hidden; }
    .shot img { width: 100%; max-height: 600px; object-fit: cover; display: block; border-radius: 10px; }
    .video { position: relative; aspect-ratio: 16/9; } .video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: 10px; }
    .medialink { padding: .8rem; text-align: center; background: rgba(255,255,255,.04); border: 1px solid var(--border); border-radius: 10px; color: var(--green); font-weight: 700; }
    .p-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 1.2rem; }
    .like { background: rgba(255,255,255,.04); border: 1px solid var(--border-2); color: var(--text); padding: .4rem .8rem; border-radius: 999px; cursor: pointer; }
    .like[disabled] { opacity: .6; cursor: default; }
  </style>
</Base>
