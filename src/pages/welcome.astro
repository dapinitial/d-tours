---
import Base from '../layouts/Base.astro';
import { supabaseServer, authConfigured } from '../lib/supabaseServer';

export const prerender = false;

// Onboarding: a SIGNED-IN user with no trip yet names + describes one, then
// provision_trip clones the template into their new private trip. Gate on
// AUTHENTICATION (getUser) — NOT crew membership — because a brand-new user has
// no crew row yet, and that's exactly who this page exists to onboard.
if (authConfigured) {
  const sb = supabaseServer(Astro.cookies, Astro.request.headers);
  const { data: { user } } = await sb.auth.getUser();
  if (!user) return Astro.redirect('/login?next=/welcome');
  // Already owns a trip? Skip straight to the CMS.
  const { data: crew } = await sb.from('crew').select('tenant_id').eq('email', user.email).maybeSingle();
  if (crew?.tenant_id) return Astro.redirect('/cms');
}
---
<Base title="D-Tours · Name your trip">
  <section>
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow">🎒 One last step</p>
        <h2>Name your trip</h2>
        <p>Tell us what you're planning and we'll build your private trip, tailored to it. You can change everything later — the dossier sections even shape themselves to what you're doing.</p>
      </div>
      <form id="welcome-form" class="card login-card">
        <label>Trip name
          <input type="text" id="name" name="name" placeholder="My World Cup Trip" required maxlength="80" />
        </label>
        <label>What's the trip? <span class="hint">(climbing, road trip, World Cup, SCUBA… one line)</span>
          <textarea id="intent" name="intent" rows="3" maxlength="400" placeholder="Catching World Cup matches in Seattle, then a Pacific Northwest road trip with some easy hikes."></textarea>
        </label>
        <fieldset class="start-choice">
          <legend>Start from</legend>
          <label class="radio"><input type="radio" name="start" value="blank" checked /> <span><strong>Blank</strong> — build it your way (recommended)</span></label>
          <label class="radio"><input type="radio" name="start" value="template" /> <span>The <strong>Seattle / PNW example</strong> — chapters &amp; stops to edit down</span></label>
        </fieldset>
        <button class="btn" type="submit">Create my trip →</button>
        <p class="msg" id="msg"></p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('welcome-form');
    const msg = document.getElementById('msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = (document.getElementById('name')).value.trim();
      const intent = (document.getElementById('intent')).value.trim();
      const from_template = (form.querySelector('input[name="start"]:checked'))?.value === 'template';
      if (!name) { msg.textContent = 'Give your trip a name.'; msg.className = 'msg err'; return; }
      msg.textContent = 'Setting up your trip…'; msg.className = 'msg';
      const btn = form.querySelector('button'); if (btn) btn.disabled = true;
      try {
        const res = await fetch('/api/provision', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, intent, from_template }),
        });
        const data = await res.json();
        if (data.ok) { msg.textContent = '✅ Trip created! Taking you in…'; msg.className = 'msg ok'; location.href = '/cms'; }
        else { msg.textContent = data.error || 'Something went wrong.'; msg.className = 'msg err'; if (btn) btn.disabled = false; }
      } catch {
        msg.textContent = 'Network error — try again.'; msg.className = 'msg err'; if (btn) btn.disabled = false;
      }
    });
  </script>

  <style>
    .container.narrow { width: min(100% - 2.5rem, 520px); }
    .login-card { display: grid; gap: 1rem; }
    .login-card label { display: grid; gap: .35rem; font-size: .9rem; color: var(--muted); }
    .login-card .hint { color: var(--muted); font-weight: 400; }
    .login-card input, .login-card textarea { width: 100%; background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .8rem .9rem; font: inherit; }
    .login-card input { min-height: 46px; }
    .start-choice { display: grid; gap: .5rem; border: 1px solid var(--border); border-radius: 10px; padding: .8rem .9rem; margin: 0; }
    .start-choice legend { font-size: .8rem; color: var(--muted); padding: 0 .3rem; }
    .start-choice .radio { display: flex; align-items: flex-start; gap: .6rem; font-size: .9rem; color: var(--text); cursor: pointer; }
    .start-choice .radio input { width: auto; min-height: 0; margin-top: .2rem; }
    .msg { margin: 0; min-height: 1.2em; font-size: .9rem; }
    .msg.ok { color: var(--green); } .msg.err { color: var(--red); }
  </style>
</Base>
