---
import Base from '../../layouts/Base.astro';
import { getObjective, getSources, getObjectiveComments, getSignups } from '../../lib/data';
import type { ObjectiveBeta } from '../../lib/types';
import { isSendDay, sendWindow, windowLabel } from '../../lib/weather';
import { extImg } from '../../lib/packet';
import { supabaseServer, authConfigured } from '../../lib/supabaseServer';

export const prerender = false;

const { id } = Astro.params;
const obj = id ? await getObjective(id) : null;
if (!obj) return Astro.redirect('/plan');
const b: ObjectiveBeta = (obj.beta as any) ?? {};
const hasBeta = obj.beta && Object.keys(obj.beta as any).length > 0;
// Owner-only Smart Commit. Wrapped so a failed/blocked auth check NEVER blanks this
// public page — on any error we just fall through to not-owner (no button).
let isOwner = !authConfigured; // local/mock dev → treat as owner
if (authConfigured) {
  try {
    const sbU = supabaseServer(Astro.cookies, Astro.request.headers);
    const { data: { user } } = await sbU.auth.getUser();
    if (user?.email) {
      const { data: crew } = await sbU.from('crew').select('tenant_id').eq('email', user.email).eq('is_owner', true).maybeSingle();
      isOwner = !!crew;
    }
  } catch { isOwner = false; }
}
const commitDayTypes = [
  { v: 'alpine', label: '🏔️ Alpine' },
  { v: 'crag', label: '🪨 Crag' },
  { v: 'travel', label: '🚐 Travel' },
  { v: 'recovery', label: '🧖 Recovery' },
  { v: 'remote-work', label: '💻 Remote' },
];
// Seed links Shotgun is working from (pinned to this objective).
const seeds = (await getSources((obj as any).tenant_id)).filter((s: any) => s.objective_id === obj.id);
const comments = await getObjectiveComments(obj.id);
const signups = await getSignups(obj.id);
const climbers = signups.filter((s) => s.role === 'climb');
const riders = signups.filter((s) => s.role === 'ride');
const fmtDate = (d?: string) => d ? new Date(d).toLocaleDateString([], { month: 'short', day: 'numeric' }) : '';
const sev: Record<string, string> = { low: 'chip', med: 'chip amber', high: 'chip red' };
const fgEmoji: Record<string, string> = { edible: '🍃', poisonous: '☠️', medicinal: '⚕️', wildlife: '🦌', snake: '🐍', insect: '🦟', landmark: '🪨' };
// Route field-guide photos (external Wikimedia) through our first-party /extimg
// proxy so they load on DNS-filtered wifi AND cache offline in the packet.
const fg = (b.field_guide ?? []).map((f) => ({ ...f, photo: f.photo ? extImg(f.photo) : f.photo }));
// WMO weather-code → emoji for the auto-refreshed forecast row.
const wxEmoji = (c: number): string => {
  if (c === 0) return '☀️';
  if (c <= 2) return '🌤️';
  if (c === 3) return '☁️';
  if (c <= 48) return '🌫️';
  if (c <= 57) return '🌦️';
  if (c <= 67) return '🌧️';
  if (c <= 77) return '🌨️';
  if (c <= 82) return '🌧️';
  if (c <= 86) return '🌨️';
  return '⛈️';
};
const fc = b.conditions?.forecast;
const fcAge = fc?.updated_at ? Math.round((Date.now() - new Date(fc.updated_at).getTime()) / 3600000) : null;
const win = sendWindow(fc?.days);
const dayName = (d: string) => new Date(d + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'short' });
// "Before you leave" checklist — auto-built from whatever this dossier knows.
const checklist = [
  b.rack && `Rack — ${b.rack}`,
  b.ropes && `Ropes — ${b.ropes}`,
  (b.footwear || b.mountaineering) && `Footwear / snow kit`,
  (b.permits || b.access?.pass) && `Permit / pass sorted`,
  (b.water && b.water.length > 0) && `Water — filter + plan refills`,
  b.food && `Food + calories packed`,
  (b.med_kit && b.med_kit.length > 0) && `First-aid + repair kit`,
  `📋 Left your plan + ETA with someone`,
  `🛰️ inReach check-in plan set`,
  `🌤️ Weather + 🔥 fire/smoke checked`,
  `🔦 Headlamp + extra layer + water`,
].filter(Boolean) as string[];
---
<Base title={`${obj.name} · Beta · D-Tours`} description={b.summary ?? `${obj.grade} · ${obj.region}`}>
  <section>
    <div class="container narrow">
      <a href="/plan" class="muted back">← all objectives</a>

      <header class="obj-head">
        <h1>{obj.name}</h1>
        <div class="meta">
          <span class="mono">{obj.region}</span>
          <span class="mono">{obj.grade}</span>
          <span class="mono">{obj.commitment}</span>
          {obj.discipline && <span class="chip sky">{obj.discipline}</span>}
          <span class={sev[obj.severity]}>{obj.hazard}</span>
        </div>
        {obj.gpx_url && <a class="btn gpx" href={obj.gpx_url} target="_blank" rel="noopener">⬇ GPX / track{!obj.gpx_verified && <span class="gpx-prov" title="Auto-found track — verify against Gaia">⚠ unverified</span>}</a>}
      </header>

      {isOwner && (
        <div class="smart-commit" data-oid={obj.id} data-name={obj.name} data-grade={obj.grade ?? ''} data-region={obj.region ?? ''} data-lat={obj.lat ?? ''} data-lng={obj.lng ?? ''}>
          <button class="btn sc-open" type="button">📅 Add to a day</button>
          <div class="sc-panel" hidden>
            <p class="sc-head">🛰️ Shotgun suggests<span class="sc-rough" hidden> · rough — confirm the date</span></p>
            <div class="sc-list" aria-live="polite"></div>
            <div class="sc-manual">
              <span class="muted tiny">or pick:</span>
              <input class="sc-date" type="date" aria-label="commit date" />
              <select class="sc-type" aria-label="day type">
                {commitDayTypes.map((d) => <option value={d.v} selected={d.v === (obj.day_type ?? '')}>{d.label}</option>)}
              </select>
              <button class="btn sm sc-commit-manual" type="button">Commit</button>
            </div>
            <p class="sc-status" hidden></p>
          </div>
        </div>
      )}

      <!-- 🚐 CARAVAN SIGN-UP — two distinct roles: roped up, or holding down the rig -->
      <section class="block caravan">
        <h2>🚐 Join the caravan</h2>
        {(climbers.length > 0 || riders.length > 0) && (
          <div class="cv-roster">
            {climbers.length > 0 && <p><span class="cv-rl">🧗 Climbing party:</span> {climbers.map((s) => s.name).join(', ')}</p>}
            {riders.length > 0 && <p><span class="cv-rl">🚐 Rolling deep (rig crew):</span> {riders.map((s) => s.name).join(', ')}</p>}
          </div>
        )}
        <div class="cv-btns">
          <button class="btn cv-join" data-role="climb" type="button">🧗 Join climb</button>
          <button class="btn ghost cv-join" data-role="ride" type="button">🚐 Ride along</button>
        </div>
        <form class="cv-form" id="cv-form" data-id={obj.id} hidden>
          <p class="cv-prompt" id="cv-prompt"></p>
          <input id="cv-name" placeholder="Your name" autocomplete="name" required />
          <input id="cv-contact" placeholder="Email or phone (so we can coordinate)" />
          <input id="cv-note" placeholder="Note — rope, gear, dog, solar skills… (optional)" />
          <input type="hidden" id="cv-role" />
          <div class="cv-foot">
            <button class="btn" type="submit">Send sign-up</button>
            <button class="btn ghost" type="button" id="cv-cancel">Cancel</button>
          </div>
          <p class="msg" id="cv-msg"></p>
        </form>
      </section>
      <script>
        (() => {
          const form = document.getElementById('cv-form');
          if (!form) return;
          const oid = form.dataset.id;
          const promptEl = document.getElementById('cv-prompt');
          const roleInput = document.getElementById('cv-role');
          const msg = document.getElementById('cv-msg');
          const PROMPTS = {
            climb: '🧗 Roped up on the objective with us — tell us what you climb and what you’ll bring.',
            ride: '🚐 Hold down the rig: guard the car + Starlink, run the solar to harvest power, and be the welcome party when we top out. No climbing required.',
          };
          const val = (id) => document.getElementById(id).value;
          document.querySelectorAll('.cv-join').forEach((b) => b.addEventListener('click', () => {
            const role = b.dataset.role;
            roleInput.value = role;
            promptEl.textContent = PROMPTS[role] || '';
            form.hidden = false;
            document.getElementById('cv-name').focus();
          }));
          document.getElementById('cv-cancel')?.addEventListener('click', () => { form.hidden = true; });
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            msg.className = 'msg'; msg.textContent = 'Sending…';
            try {
              const r = await fetch('/api/signup', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ objective_id: oid, role: roleInput.value, name: val('cv-name'), contact: val('cv-contact'), note: val('cv-note') }),
              });
              const j = await r.json();
              if (j.ok) {
                msg.className = 'msg ok';
                msg.textContent = j.role === 'ride'
                  ? '🚐 You’re on the rig crew — David will confirm. Thanks for holding it down!'
                  : '🧗 You’re in — David will confirm. See you on the rock!';
                form.reset();
              } else { msg.className = 'msg err'; msg.textContent = j.error || 'Try again.'; }
            } catch { msg.className = 'msg err'; msg.textContent = 'Network hiccup — try again.'; }
          });
        })();
      </script>
      <style>
        /* .block has no style of its own → it was inheriting the global section{padding:7rem}.
           Reset it so the ~20 dossier sections stack tight; caravan keeps its own card padding. */
        .block { padding-block: 0; margin-block: 1.5rem; }
        section.caravan { background: linear-gradient(180deg, rgba(52,211,153,.06), var(--panel-2)); padding: 1.1rem 1.2rem; border: 1px solid var(--border); border-radius: var(--radius); }
        .cv-roster { margin: 0 0 .8rem; font-size: .9rem; }
        .cv-roster p { margin: .2rem 0; }
        .cv-rl { font-weight: 700; }
        .cv-btns { display: flex; gap: .6rem; flex-wrap: wrap; }
        .cv-form { display: grid; gap: .55rem; margin-top: .9rem; max-width: 34rem; }
        .cv-form[hidden] { display: none; }
        .cv-prompt { margin: 0; font-size: .85rem; color: var(--muted); }
        .cv-form input { background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .65rem .8rem; font: inherit; }
        .cv-foot { display: flex; gap: .6rem; }
        .cv-form .msg { font-size: .85rem; margin: 0; min-height: 1.1em; }
        .cv-form .msg.ok { color: var(--green); } .cv-form .msg.err { color: var(--red); }
      </style>

      {b.at_a_glance && (
        <div class="glance">
          {b.at_a_glance.hike_type && <span class="g-chip">🥾 {b.at_a_glance.hike_type}</span>}
          {b.at_a_glance.trail && <span class="g-chip">🧭 {b.at_a_glance.trail}</span>}
          {b.at_a_glance.road && <span class="g-chip">🚙 {b.at_a_glance.road}</span>}
          {b.at_a_glance.bugs && <span class="g-chip">🦟 {b.at_a_glance.bugs}</span>}
          {b.at_a_glance.snow && <span class="g-chip">❄️ {b.at_a_glance.snow}</span>}
        </div>
      )}

      {!hasBeta && (
        <div class="pending card">
          <span class="big">🔍</span>
          <p><strong>Shotgun's compiling this dossier.</strong></p>
          <p class="muted">{seeds.length > 0 ? `${seeds.length} link(s) seeded — research underway.` : 'Seed a few links in the CMS and Shotgun will fill in the beta, gear, routes, camp, permits and conditions.'}</p>
        </div>
      )}

      {b.summary && <p class="summary">{b.summary}</p>}

      {(b.trailhead?.name || b.trailhead?.gmaps_url || b.trailhead?.drive || b.last_services || b.signal) && (
        <section class="block">
          <h2>🚗 Getting there & comms</h2>
          {b.trailhead?.name && <p><strong>Trailhead:</strong> {b.trailhead.name}</p>}
          {b.trailhead?.drive && <p class="muted">{b.trailhead.drive}</p>}
          {b.trailhead?.gmaps_url && <a class="btn ghost sm" href={b.trailhead.gmaps_url} target="_blank" rel="noopener">🗺️ Google Maps directions</a>}
          {b.last_services && <p><strong>⛽ Last services:</strong> {b.last_services}</p>}
          {b.signal && <p><strong>📶 Cell signal:</strong> {b.signal}</p>}
        </section>
      )}

      {b.photos && b.photos.length > 0 && (
        <div class="photos">
          {b.photos.map((p) => (
            <figure><img src={extImg(p.url)} loading="lazy" alt={p.caption ?? obj.name} />{p.caption && <figcaption>{p.caption}</figcaption>}</figure>
          ))}
        </div>
      )}

      {b.routes && b.routes.length > 0 && (
        <section class="block">
          <h2>🧗 Routes</h2>
          <div class="routes">
            {b.routes.map((r) => (
              <div class="route">
                <div class="r-top"><span class="r-name">{r.url ? <a href={r.url} target="_blank" rel="noopener">{r.name}</a> : r.name}</span>{r.grade && <span class="r-grade mono">{r.grade}</span>}</div>
                {r.note && <div class="muted r-note">{r.note}</div>}
              </div>
            ))}
          </div>
        </section>
      )}

      {(b.approach || b.descent || b.season) && (
        <section class="block">
          <h2>🥾 Approach · descent · season</h2>
          {b.approach && <p><strong>Approach:</strong> {b.approach}</p>}
          {b.descent && <p><strong>⬇️ Descent:</strong> {b.descent}</p>}
          {b.season && <p><strong>🗓️ Season:</strong> {b.season}</p>}
        </section>
      )}

      <div class="cols">
        {(b.rack || b.ropes || b.footwear || b.mountaineering || b.food) && (
          <section class="block">
            <h2>🎒 Gear & food</h2>
            {b.rack && <p><strong>Rack:</strong> {b.rack}</p>}
            {b.ropes && <p><strong>Ropes:</strong> {b.ropes}</p>}
            {b.footwear && <p><strong>Footwear:</strong> {b.footwear}</p>}
            {b.mountaineering && <p><strong>🪓 Mountaineering:</strong> {b.mountaineering}</p>}
            {b.glacier && <p><strong>Glacier:</strong> {b.glacier}</p>}
            {b.food && <p><strong>🍫 Food:</strong> {b.food}</p>}
            {b.med_kit && b.med_kit.length > 0 && <p><strong>🩹 Med/repair kit:</strong> {b.med_kit.join(' · ')}</p>}
          </section>
        )}
        {b.skills && b.skills.length > 0 && (
          <section class="block">
            <h2>🪢 Skills needed</h2>
            <ul>{b.skills.map((s) => <li>{s}</li>)}</ul>
          </section>
        )}
      </div>

      {(b.alpine_start || b.altitude) && (
        <section class="block">
          <h2>⏰ Start & altitude</h2>
          {b.alpine_start && <p><strong>🌄 Timing:</strong> {b.alpine_start}</p>}
          {b.altitude && <p><strong>🫁 Altitude & sun:</strong> {b.altitude}</p>}
        </section>
      )}

      {hasBeta && checklist.length > 0 && (
        <section class="block checklist">
          <h2>✅ Before you leave the trailhead</h2>
          <p class="muted tiny">Auto-built from this dossier — ticks save on this device.</p>
          <ul class="check" id="pre-check" data-obj={obj.id}>
            {checklist.map((c, i) => (
              <li><label><input type="checkbox" data-ci={i} /> <span>{c}</span></label></li>
            ))}
          </ul>
        </section>
      )}

      {(b.land || b.camp || b.free_camp || b.water || b.permits || b.toilet || b.fire_rules) && (
        <section class="block">
          <h2>🏕️ Land · camp · water · permits</h2>
          {b.land && <p><strong>🪧 Land & passes:</strong> {b.land}</p>}
          {b.fire_rules && <p><strong>🔥 Campfires:</strong> {b.fire_rules}</p>}
          {b.free_camp && b.free_camp.length > 0 && <p><strong>🆓 Free camping nearby:</strong></p>}
          {b.free_camp && <ul>{b.free_camp.map((c) => <li>{c}</li>)}</ul>}
          {b.camp && b.camp.length > 0 && <p><strong>Camp:</strong></p>}
          {b.camp && <ul>{b.camp.map((c) => <li>{c}</li>)}</ul>}
          {b.water && <p><strong>💧 Water:</strong> {b.water.join(' · ')}</p>}
          {b.permits && <p><strong>📋 Permits:</strong> {b.permits}</p>}
          {b.toilet && <p><strong>🚽 Toilet:</strong> {b.toilet}</p>}
        </section>
      )}

      {(b.hazards || b.wildlife || b.fire || b.bail || (b.emergency && b.emergency.length > 0)) && (
        <section class="block warn">
          <h2>⚠️ Hazards · fire · emergency</h2>
          {b.hazards && <ul>{b.hazards.map((h) => <li>{h}</li>)}</ul>}
          {b.wildlife && <p class="muted">{b.wildlife}</p>}
          {b.fire && <p><strong>🔥 Fire & smoke:</strong> {b.fire}</p>}
          {b.bail && <p><strong>🪂 Bail / retreat:</strong> {b.bail}</p>}
          {b.emergency && b.emergency.length > 0 && (
            <div class="emergency">
              <p><strong>🆘 Emergency contacts</strong></p>
              <ul>{b.emergency.map((e) => <li>{e.label}{e.phone && <a class="tel" href={`tel:${e.phone.replace(/[^+\d]/g, '')}`}> {e.phone}</a>}{e.note && <span class="muted"> — {e.note}</span>}</li>)}</ul>
            </div>
          )}
        </section>
      )}

      {b.conditions && (fc || b.conditions.weather_url || b.conditions.mountain_forecast_url || b.conditions.avalanche_url || b.conditions.fire_url || b.conditions.bugs) && (
        <section class="block">
          <h2>🌤️ Live conditions</h2>
          {fc && fc.days?.length > 0 && (
            <div class="wx">
              {win && <div class="wx-window">🟢 Send window: <strong>{windowLabel(fc.days, win)}</strong></div>}
              <div class="wx-row">
                {fc.days.slice(0, 5).map((d) => (
                  <div class:list={['wx-day', { send: isSendDay(d) }]}>
                    <div class="wx-dow">{dayName(d.date)}</div>
                    <div class="wx-icon">{wxEmoji(d.code)}</div>
                    <div class="wx-temp"><span class="hi">{d.tmax}°</span> <span class="lo">{d.tmin}°</span></div>
                    {d.precip_prob > 10 && <div class="wx-precip">💧{d.precip_prob}%</div>}
                    {d.wind >= 20 && <div class="wx-wind">💨{d.wind}</div>}
                  </div>
                ))}
              </div>
              <p class="wx-note muted tiny">Auto-updated {fcAge != null ? (fcAge < 1 ? 'just now' : `${fcAge}h ago`) : ''} · °F · tap a link for the mountain-specific picture ↓</p>
            </div>
          )}
          <div class="cond-links">
            {b.conditions.weather_url && <a class="btn ghost sm" href={b.conditions.weather_url} target="_blank" rel="noopener">🌦️ Weather</a>}
            {b.conditions.mountain_forecast_url && <a class="btn ghost sm" href={b.conditions.mountain_forecast_url} target="_blank" rel="noopener">⛰️ Mountain Forecast</a>}
            {b.conditions.avalanche_url && <a class="btn ghost sm" href={b.conditions.avalanche_url} target="_blank" rel="noopener">🏔️ Avalanche</a>}
            {b.conditions.fire_url && <a class="btn ghost sm" href={b.conditions.fire_url} target="_blank" rel="noopener">🔥 Fire / smoke</a>}
          </div>
          {b.conditions.bugs && <p class="muted">🦟 {b.conditions.bugs}</p>}
        </section>
      )}

      {fg.length > 0 ? (
        <section class="block">
          <h2>👀 In the field</h2>
          <p class="muted tiny">Tap any for ID, edibility &amp; first-aid.</p>
          <div class="fg-chips">
            {fg.map((f, i) => <button class="fg-chip" data-fg={i} data-kind={f.kind} type="button">{fgEmoji[f.kind] ?? '•'} {f.name}{f.photo && <span class="fg-cam" title="has a photo">📷</span>}</button>)}
          </div>
        </section>
      ) : (b.watch_for && b.watch_for.length > 0 && (
        <section class="block">
          <h2>👀 Keep an eye out for</h2>
          <p class="muted tiny">Cool plants, wildlife, edibles &amp; gems — and what to steer clear of.</p>
          <ul>{b.watch_for.map((w) => <li>{w}</li>)}</ul>
        </section>
      ))}

      {b.access && (b.access.visitor_center || b.access.ranger_station || b.access.pass || b.access.url) && (
        <section class="block">
          <h2>🏛️ Access · ranger · pass</h2>
          {b.access.visitor_center && <p><strong>Visitor center:</strong> {b.access.visitor_center}</p>}
          {b.access.ranger_station && <p><strong>Ranger station:</strong> {b.access.ranger_station}</p>}
          {b.access.pass && <p><strong>Pass:</strong> {b.access.pass}</p>}
          {b.access.url && <a class="btn ghost sm" href={b.access.url} target="_blank" rel="noopener">Official page ↗</a>}
        </section>
      )}

      {b.fishing && (
        <section class="block">
          <h2>🎣 Fishing</h2>
          <p>{b.fishing}</p>
        </section>
      )}

      {b.poi && b.poi.length > 0 && (
        <section class="block">
          <h2>🔭 Points of interest</h2>
          <p class="muted tiny">Fire lookouts, old mines, wreckage, historic relics nearby.</p>
          <ul>{b.poi.map((p) => <li>{p.url ? <a href={p.url} target="_blank" rel="noopener">{p.name}</a> : <strong>{p.name}</strong>}{p.note && <span class="muted"> — {p.note}</span>}</li>)}</ul>
        </section>
      )}

      {b.nearby && b.nearby.length > 0 && (
        <section class="block">
          <h2>📍 Nearby & other interest</h2>
          <ul>{b.nearby.map((n) => <li>{n}</li>)}</ul>
        </section>
      )}

      {seeds.length > 0 && (
        <section class="block">
          <h2>🔗 Beta sources</h2>
          <p class="muted tiny">Links Shotgun reads to keep this dossier current.</p>
          <ul class="seeds">{seeds.map((s: any) => <li><a href={s.url} target="_blank" rel="noopener">{s.title || s.url}</a> {s.tag && <span class="mono muted">· {s.tag}</span>}</li>)}</ul>
        </section>
      )}

      <section class="block comments">
        <h2>💬 Comments {comments.length > 0 && <span class="muted">({comments.length})</span>}</h2>
        {comments.map((c: any) => (
          <div class="cmt"><span class="c-author">{c.author}</span> <span class="c-when muted">{fmtDate(c.created_at)}</span><p>{c.body}</p></div>
        ))}
        <form class="cmt-form" id="cmt-form" data-id={obj.id}>
          <input id="c-name" placeholder="Your name" />
          <textarea id="c-body" rows="2" placeholder="Beta, a tip, a question, a hello…" required></textarea>
          <div class="cmt-foot">
            <button class="btn" type="submit">Post comment</button>
            <p class="msg" id="c-msg"></p>
          </div>
        </form>
        <p class="muted tiny">Comments are reviewed before they show up.</p>
      </section>

      {fg.length > 0 && (
        <Fragment>
          <script type="application/json" id="fg-data" set:html={JSON.stringify(fg)}></script>
          <div id="fg-modal" class="fg-modal" hidden>
            <div class="fg-card">
              <button class="fg-close" type="button" aria-label="Close">✕</button>
              <div class="fg-body"></div>
            </div>
          </div>
        </Fragment>
      )}
    </div>
  </section>

  <script>
    document.getElementById('cmt-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLElement;
      const msg = document.getElementById('c-msg');
      const body = (document.getElementById('c-body') as HTMLTextAreaElement).value.trim();
      if (!body) return;
      msg.textContent = 'Posting…'; msg.className = 'msg';
      try {
        const r = await fetch('/api/comment', { method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target: 'objective', id: (f as HTMLElement).dataset.id, author: (document.getElementById('c-name') as HTMLInputElement).value, body }) });
        const j = await r.json();
        if (j.ok) { msg.textContent = '🙏 Posted — it shows once reviewed!'; msg.className = 'msg ok'; (document.getElementById('c-body') as HTMLTextAreaElement).value = ''; }
        else { msg.textContent = j.error || 'Try again.'; msg.className = 'msg err'; }
      } catch { msg.textContent = 'Network hiccup — try again.'; msg.className = 'msg err'; }
    });
  </script>

  <script>
    // 📅 Smart Commit — fetch Shotgun's date suggestions, commit one (or a manual pick)
    // to the calendar via the existing /api/itinerary add path. Owner-only widget.
    (() => {
      const root = document.querySelector('.smart-commit');
      if (!root) return;
      const oid = root.dataset.oid;
      const panel = root.querySelector('.sc-panel');
      const list = root.querySelector('.sc-list');
      const roughTag = root.querySelector('.sc-rough');
      const status = root.querySelector('.sc-status');
      const manual = root.querySelector('.sc-manual');
      const DAY_EMOJI = { alpine: '🏔️', crag: '🪨', travel: '🚐', recovery: '🧖', 'remote-work': '💻' };
      const pretty = (d) => new Date(d + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
      const shortDate = (d) => new Date(d + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

      async function commit(date, dayType) {
        const m = new Date(date + 'T12:00:00');
        const order = (m.getMonth() + 1) * 100 + m.getDate(); // rough date-sequence in the itinerary
        const stop = {
          id: 'stop-' + oid,
          name: root.dataset.name, emoji: DAY_EMOJI[dayType] || '🧗', sub: root.dataset.grade,
          region: root.dataset.region, flex: 'soft', status: 'confirmed', kind: 'sidequest', order,
          objective_id: oid, start_date: date, date: shortDate(date), day_type: dayType,
          ...(root.dataset.lat ? { lat: parseFloat(root.dataset.lat) } : {}),
          ...(root.dataset.lng ? { lng: parseFloat(root.dataset.lng) } : {}),
        };
        try {
          const r = await fetch('/api/itinerary', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'add', stop }) });
          const j = await r.json().catch(() => ({}));
          if (j.ok) {
            list.innerHTML = ''; manual.hidden = true; roughTag.hidden = true; status.hidden = false;
            status.innerHTML = '✓ Committed to <b>' + pretty(date) + '</b> — <a href="/calendar">see it on the calendar →</a>';
          } else { status.hidden = false; status.textContent = j.error || 'Commit failed.'; }
        } catch { status.hidden = false; status.textContent = 'Network hiccup — try again.'; }
      }

      let loaded = false;
      root.querySelector('.sc-open').addEventListener('click', async () => {
        panel.hidden = !panel.hidden;
        if (loaded || panel.hidden) return;
        loaded = true;
        list.innerHTML = '<p class="muted tiny">thinking…</p>';
        try {
          const r = await fetch('/api/commit-suggestions?objective=' + encodeURIComponent(oid));
          const j = await r.json();
          list.innerHTML = '';
          if (!j.ok || !(j.suggestions || []).length) { list.innerHTML = '<p class="muted tiny">No smart pick yet — choose a date below.</p>'; return; }
          if (j.suggestions[0].rough) roughTag.hidden = false;
          for (const s of j.suggestions) {
            const row = document.createElement('div'); row.className = 'sc-row';
            const info = document.createElement('div'); info.className = 'sc-info';
            info.innerHTML = '<span class="sc-when">' + (DAY_EMOJI[s.dayType] || '🧗') + ' ' + pretty(s.date) + ' · ' + s.chapterEmoji + ' ' + s.chapterName + '</span><span class="sc-why muted tiny">' + s.reasons.join(' · ') + '</span>';
            const pick = document.createElement('button'); pick.className = 'btn sm sc-pick'; pick.type = 'button'; pick.textContent = 'Commit';
            pick.addEventListener('click', () => commit(s.date, s.dayType));
            row.append(info, pick);
            list.appendChild(row);
          }
        } catch { list.innerHTML = '<p class="muted tiny">Could not load suggestions — choose a date below.</p>'; }
      });

      root.querySelector('.sc-commit-manual').addEventListener('click', () => {
        const date = root.querySelector('.sc-date').value;
        const type = root.querySelector('.sc-type').value || 'alpine';
        if (!date) { status.hidden = false; status.textContent = 'Pick a date first.'; return; }
        commit(date, type);
      });
    })();
  </script>

