    .r-top { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
    .r-name { font-weight: 700; } .r-name a { color: var(--text); } .r-name a:hover { color: var(--green); }
    .r-grade { color: var(--green); font-size: .8rem; }
    .r-note { font-size: .9rem; margin-top: .2rem; }
    .wx { margin-bottom: 1rem; }
    .wx-window { display: inline-block; font-size: .82rem; font-weight: 700; color: var(--green); background: rgba(52,211,153,.12); border: 1px solid rgba(52,211,153,.35); padding: .25rem .7rem; border-radius: 999px; margin-bottom: .6rem; }
    .wx-row { display: flex; gap: .5rem; overflow-x: auto; padding-bottom: .3rem; }
    .wx-day { flex: 0 0 auto; min-width: 68px; text-align: center; padding: .6rem .4rem; background: rgba(255,255,255,.03); border: 1px solid var(--border); border-radius: 10px; }
    .wx-day.send { border-color: rgba(52,211,153,.5); background: rgba(52,211,153,.08); }
    .wx-dow { font-size: .72rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
    .wx-icon { font-size: 1.5rem; line-height: 1.6; }
    .wx-temp { font-size: .82rem; } .wx-temp .hi { font-weight: 700; } .wx-temp .lo { color: var(--muted); }
    .wx-precip, .wx-wind { font-size: .68rem; color: var(--sky, #38bdf8); margin-top: .15rem; }
