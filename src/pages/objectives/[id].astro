    .fg-close { position: absolute; top: .6rem; right: .7rem; background: transparent; border: none; color: var(--muted); font-size: 1.2rem; cursor: pointer; }
    .fg-body h3 { margin: .3rem 0 .5rem; }
    .fg-photo { display: block; width: 100%; max-width: 90vw; max-height: clamp(140px, 38vh, 300px); object-fit: contain; border-radius: 10px; margin-bottom: .8rem; background: rgba(0,0,0,.25); }
    .fg-kind { display: inline-block; font-size: .74rem; font-weight: 700; padding: .2rem .55rem; border-radius: 999px; background: rgba(255,255,255,.06); }
    .kind-poisonous, .kind-snake { color: var(--red); } .kind-edible { color: var(--green); } .kind-medicinal { color: var(--sky); }
    .fg-treat { color: var(--amber); }
  </style>
  <script>
    (() => {
      const list = document.getElementById('pre-check');
      if (!list) return;
      const key = 'dtours-check-' + (list.dataset.obj || '');
      let state = {};
      try { state = JSON.parse(localStorage.getItem(key) || '{}'); } catch {}
      list.querySelectorAll('input[type=checkbox]').forEach((cb) => {
        const i = cb.dataset.ci;
        cb.checked = !!state[i];
        cb.closest('li')?.classList.toggle('done', cb.checked);
        cb.addEventListener('change', () => {
          state[i] = cb.checked;
          cb.closest('li')?.classList.toggle('done', cb.checked);
          try { localStorage.setItem(key, JSON.stringify(state)); } catch {}
        });
      });
    })();
  </script>

