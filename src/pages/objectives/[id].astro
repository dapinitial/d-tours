    .fg-chip[data-kind="edible"] { border-color: rgba(52,211,153,.45); }
    .fg-chip[data-kind="medicinal"] { border-color: rgba(56,189,248,.45); }
    .fg-modal { position: fixed; inset: 0; z-index: 2000; background: rgba(0,0,0,.62); display: grid; place-items: center; padding: 1rem; }
