    .cond-links { display: flex; gap: .5rem; flex-wrap: wrap; }
    .seeds a { color: var(--sky); }
  </style>
  <script>
    (() => {
      const el = document.getElementById('fg-data');
      const modal = document.getElementById('fg-modal');
      if (!el || !modal) return;
      const data = JSON.parse(el.textContent || '[]');
      const body = modal.querySelector('.fg-body');
      const EMOJI = { edible:'🍃', poisonous:'☠️', medicinal:'⚕️', wildlife:'🦌', snake:'🐍', insect:'🦟', landmark:'🪨' };
      const LABEL = { edible:'Edible', poisonous:'Poisonous — do not touch/eat', medicinal:'Medicinal', wildlife:'Wildlife', snake:'Venomous', insect:'Biting/stinging', landmark:'Landmark' };
      const esc = (s) => (s || '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
      const open = (i) => {
        const f = data[i]; if (!f || !body) return;
        body.innerHTML =
          (f.photo ? `<img class="fg-photo" src="${esc(f.photo)}" alt="${esc(f.name)}" loading="lazy">` : '') +
          `<div class="fg-kind kind-${esc(f.kind)}">${EMOJI[f.kind]||'•'} ${LABEL[f.kind]||''}</div>` +
          `<h3>${esc(f.name)}</h3>` +
          (f.note ? `<p>${esc(f.note)}</p>` : '') +
          (f.treat ? `<p class="fg-treat"><strong>🆘 What to do:</strong> ${esc(f.treat)}</p>` : '') +
          (f.url ? `<a class="btn ghost sm" href="${esc(f.url)}" target="_blank" rel="noopener">More ↗</a>` : '');
        modal.hidden = false;
      };
      document.querySelectorAll('.fg-chip').forEach((c) => c.addEventListener('click', () => open(Number(c.dataset.fg))));
      const close = () => { modal.hidden = true; };
      modal.querySelector('.fg-close')?.addEventListener('click', close);
      modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    })();
  </script>

  <style>
    .fg-chips { display: flex; flex-wrap: wrap; gap: .5rem; }
    .fg-chip { cursor: pointer; font-size: .85rem; font-weight: 600; padding: .4rem .75rem; border-radius: 999px; border: 1px solid var(--border-2); background: rgba(255,255,255,.04); color: var(--text); transition: all .15s; }
    .fg-chip:hover { border-color: var(--green); transform: translateY(-1px); }
