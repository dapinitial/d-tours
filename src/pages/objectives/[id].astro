---
import Base from '../../layouts/Base.astro';
import { getObjective, getSources, getObjectiveComments } from '../../lib/data';
import type { ObjectiveBeta } from '../../lib/types';

export const prerender = false;

const { id } = Astro.params;
const obj = id ? await getObjective(id) : null;
if (!obj) return Astro.redirect('/plan');
const b: ObjectiveBeta = (obj.beta as any) ?? {};
const hasBeta = obj.beta && Object.keys(obj.beta as any).length > 0;
// Seed links Shotgun is working from (pinned to this objective).
const seeds = (await getSources((obj as any).tenant_id)).filter((s: any) => s.objective_id === obj.id);
const comments = await getObjectiveComments(obj.id);
const fmtDate = (d?: string) => d ? new Date(d).toLocaleDateString([], { month: 'short', day: 'numeric' }) : '';
const sev: Record<string, string> = { low: 'chip', med: 'chip amber', high: 'chip red' };
const fgEmoji: Record<string, string> = { edible: '🍃', poisonous: '☠️', medicinal: '⚕️', wildlife: '🦌', snake: '🐍', insect: '🦟', landmark: '🪨' };
const fg = b.field_guide ?? [];
// "Before you leave" checklist — auto-built from whatever this dossier knows.
const checklist = [
  b.rack && `Rack — ${b.rack}`,
  b.ropes && `Ropes — ${b.ropes}`,
  (b.footwear || b.mountaineering) && `Footwear / snow kit`,
  (b.permits || b.access?.pass) && `Permit / pass sorted`,
  (b.water && b.water.length > 0) && `Water — filter + plan refills`,
  b.food && `Food + calories packed`,
  (b.med_kit && b.med_kit.length > 0) && `First-aid + repair kit`,
  `📋 Left your plan + ETA with someone`,
  `🛰️ inReach check-in plan set`,
  `🌤️ Weather + 🔥 fire/smoke checked`,
  `🔦 Headlamp + extra layer + water`,
].filter(Boolean) as string[];
---
<Base title={`${obj.name} · Beta · D-Tours`} description={b.summary ?? `${obj.grade} · ${obj.region}`}>
  <section>
    <div class="container narrow">
      <a href="/#objectives" class="muted back">← all objectives</a>

      <header class="obj-head">
        <h1>{obj.name}</h1>
        <div class="meta">
          <span class="mono">{obj.region}</span>
          <span class="mono">{obj.grade}</span>
          <span class="mono">{obj.commitment}</span>
          {obj.discipline && <span class="chip sky">{obj.discipline}</span>}
          <span class={sev[obj.severity]}>{obj.hazard}</span>
        </div>
        {obj.gpx_url && <a class="btn gpx" href={obj.gpx_url} target="_blank" rel="noopener">⬇ GPX / track</a>}
      </header>

      {b.at_a_glance && (
        <div class="glance">
          {b.at_a_glance.hike_type && <span class="g-chip">🥾 {b.at_a_glance.hike_type}</span>}
          {b.at_a_glance.trail && <span class="g-chip">🧭 {b.at_a_glance.trail}</span>}
          {b.at_a_glance.road && <span class="g-chip">🚙 {b.at_a_glance.road}</span>}
          {b.at_a_glance.bugs && <span class="g-chip">🦟 {b.at_a_glance.bugs}</span>}
          {b.at_a_glance.snow && <span class="g-chip">❄️ {b.at_a_glance.snow}</span>}
        </div>
      )}

      {!hasBeta && (
        <div class="pending card">
          <span class="big">🔍</span>
          <p><strong>Shotgun's compiling this dossier.</strong></p>
          <p class="muted">{seeds.length > 0 ? `${seeds.length} link(s) seeded — research underway.` : 'Seed a few links in the CMS and Shotgun will fill in the beta, gear, routes, camp, permits and conditions.'}</p>
        </div>
      )}

      {b.summary && <p class="summary">{b.summary}</p>}

      {(b.trailhead?.name || b.trailhead?.gmaps_url || b.trailhead?.drive || b.last_services || b.signal) && (
        <section class="block">
          <h2>🚗 Getting there & comms</h2>
          {b.trailhead?.name && <p><strong>Trailhead:</strong> {b.trailhead.name}</p>}
          {b.trailhead?.drive && <p class="muted">{b.trailhead.drive}</p>}
          {b.trailhead?.gmaps_url && <a class="btn ghost sm" href={b.trailhead.gmaps_url} target="_blank" rel="noopener">🗺️ Google Maps directions</a>}
          {b.last_services && <p><strong>⛽ Last services:</strong> {b.last_services}</p>}
          {b.signal && <p><strong>📶 Cell signal:</strong> {b.signal}</p>}
        </section>
      )}

      {b.photos && b.photos.length > 0 && (
        <div class="photos">
          {b.photos.map((p) => (
            <figure><img src={p.url} loading="lazy" alt={p.caption ?? obj.name} />{p.caption && <figcaption>{p.caption}</figcaption>}</figure>
          ))}
        </div>
      )}

      {b.routes && b.routes.length > 0 && (
        <section class="block">
          <h2>🧗 Routes</h2>
          <div class="routes">
            {b.routes.map((r) => (
              <div class="route">
                <div class="r-top"><span class="r-name">{r.url ? <a href={r.url} target="_blank" rel="noopener">{r.name}</a> : r.name}</span>{r.grade && <span class="r-grade mono">{r.grade}</span>}</div>
                {r.note && <div class="muted r-note">{r.note}</div>}
              </div>
            ))}
          </div>
        </section>
      )}

      <div class="cols">
        {(b.rack || b.ropes || b.footwear || b.mountaineering || b.food) && (
          <section class="block">
            <h2>🎒 Gear & food</h2>
            {b.rack && <p><strong>Rack:</strong> {b.rack}</p>}
            {b.ropes && <p><strong>Ropes:</strong> {b.ropes}</p>}
            {b.footwear && <p><strong>Footwear:</strong> {b.footwear}</p>}
            {b.mountaineering && <p><strong>🪓 Mountaineering:</strong> {b.mountaineering}</p>}
            {b.glacier && <p><strong>Glacier:</strong> {b.glacier}</p>}
            {b.food && <p><strong>🍫 Food:</strong> {b.food}</p>}
            {b.med_kit && b.med_kit.length > 0 && <p><strong>🩹 Med/repair kit:</strong> {b.med_kit.join(' · ')}</p>}
          </section>
        )}
        {b.skills && b.skills.length > 0 && (
          <section class="block">
            <h2>🪢 Skills needed</h2>
            <ul>{b.skills.map((s) => <li>{s}</li>)}</ul>
          </section>
        )}
      </div>

      {(b.alpine_start || b.altitude) && (
        <section class="block">
          <h2>⏰ Start & altitude</h2>
          {b.alpine_start && <p><strong>🌄 Timing:</strong> {b.alpine_start}</p>}
          {b.altitude && <p><strong>🫁 Altitude & sun:</strong> {b.altitude}</p>}
        </section>
      )}

      {hasBeta && checklist.length > 0 && (
        <section class="block checklist">
          <h2>✅ Before you leave the trailhead</h2>
          <p class="muted tiny">Auto-built from this dossier — ticks save on this device.</p>
          <ul class="check" id="pre-check" data-obj={obj.id}>
            {checklist.map((c, i) => (
              <li><label><input type="checkbox" data-ci={i} /> <span>{c}</span></label></li>
            ))}
          </ul>
        </section>
      )}

      {(b.land || b.camp || b.free_camp || b.water || b.permits || b.toilet || b.fire_rules) && (
        <section class="block">
          <h2>🏕️ Land · camp · water · permits</h2>
          {b.land && <p><strong>🪧 Land & passes:</strong> {b.land}</p>}
          {b.fire_rules && <p><strong>🔥 Campfires:</strong> {b.fire_rules}</p>}
          {b.free_camp && b.free_camp.length > 0 && <p><strong>🆓 Free camping nearby:</strong></p>}
          {b.free_camp && <ul>{b.free_camp.map((c) => <li>{c}</li>)}</ul>}
          {b.camp && b.camp.length > 0 && <p><strong>Camp:</strong></p>}
          {b.camp && <ul>{b.camp.map((c) => <li>{c}</li>)}</ul>}
          {b.water && <p><strong>💧 Water:</strong> {b.water.join(' · ')}</p>}
          {b.permits && <p><strong>📋 Permits:</strong> {b.permits}</p>}
          {b.toilet && <p><strong>🚽 Toilet:</strong> {b.toilet}</p>}
        </section>
      )}

      {(b.hazards || b.wildlife || b.fire || b.bail || (b.emergency && b.emergency.length > 0)) && (
        <section class="block warn">
          <h2>⚠️ Hazards · fire · emergency</h2>
          {b.hazards && <ul>{b.hazards.map((h) => <li>{h}</li>)}</ul>}
          {b.wildlife && <p class="muted">{b.wildlife}</p>}
          {b.fire && <p><strong>🔥 Fire & smoke:</strong> {b.fire}</p>}
          {b.bail && <p><strong>🪂 Bail / retreat:</strong> {b.bail}</p>}
          {b.emergency && b.emergency.length > 0 && (
            <div class="emergency">
              <p><strong>🆘 Emergency contacts</strong></p>
              <ul>{b.emergency.map((e) => <li>{e.label}{e.phone && <a class="tel" href={`tel:${e.phone.replace(/[^+\d]/g, '')}`}> {e.phone}</a>}{e.note && <span class="muted"> — {e.note}</span>}</li>)}</ul>
            </div>
          )}
        </section>
      )}

      {b.conditions && (b.conditions.weather_url || b.conditions.mountain_forecast_url || b.conditions.avalanche_url || b.conditions.fire_url || b.conditions.bugs) && (
        <section class="block">
          <h2>🌤️ Live conditions</h2>
          <div class="cond-links">
            {b.conditions.weather_url && <a class="btn ghost sm" href={b.conditions.weather_url} target="_blank" rel="noopener">🌦️ Weather</a>}
            {b.conditions.mountain_forecast_url && <a class="btn ghost sm" href={b.conditions.mountain_forecast_url} target="_blank" rel="noopener">⛰️ Mountain Forecast</a>}
            {b.conditions.avalanche_url && <a class="btn ghost sm" href={b.conditions.avalanche_url} target="_blank" rel="noopener">🏔️ Avalanche</a>}
            {b.conditions.fire_url && <a class="btn ghost sm" href={b.conditions.fire_url} target="_blank" rel="noopener">🔥 Fire / smoke</a>}
          </div>
          {b.conditions.bugs && <p class="muted">🦟 {b.conditions.bugs}</p>}
        </section>
      )}

      {fg.length > 0 ? (
        <section class="block">
          <h2>👀 In the field</h2>
          <p class="muted tiny">Tap any for ID, edibility &amp; first-aid.</p>
          <div class="fg-chips">
            {fg.map((f, i) => <button class="fg-chip" data-fg={i} data-kind={f.kind} type="button">{fgEmoji[f.kind] ?? '•'} {f.name}{f.photo && <span class="fg-cam" title="has a photo">📷</span>}</button>)}
          </div>
        </section>
      ) : (b.watch_for && b.watch_for.length > 0 && (
        <section class="block">
          <h2>👀 Keep an eye out for</h2>
          <p class="muted tiny">Cool plants, wildlife, edibles &amp; gems — and what to steer clear of.</p>
          <ul>{b.watch_for.map((w) => <li>{w}</li>)}</ul>
        </section>
      ))}

      {b.access && (b.access.visitor_center || b.access.ranger_station || b.access.pass || b.access.url) && (
        <section class="block">
          <h2>🏛️ Access · ranger · pass</h2>
          {b.access.visitor_center && <p><strong>Visitor center:</strong> {b.access.visitor_center}</p>}
          {b.access.ranger_station && <p><strong>Ranger station:</strong> {b.access.ranger_station}</p>}
          {b.access.pass && <p><strong>Pass:</strong> {b.access.pass}</p>}
          {b.access.url && <a class="btn ghost sm" href={b.access.url} target="_blank" rel="noopener">Official page ↗</a>}
        </section>
      )}

      {b.fishing && (
        <section class="block">
          <h2>🎣 Fishing</h2>
          <p>{b.fishing}</p>
        </section>
      )}

      {b.poi && b.poi.length > 0 && (
        <section class="block">
          <h2>🔭 Points of interest</h2>
          <p class="muted tiny">Fire lookouts, old mines, wreckage, historic relics nearby.</p>
          <ul>{b.poi.map((p) => <li>{p.url ? <a href={p.url} target="_blank" rel="noopener">{p.name}</a> : <strong>{p.name}</strong>}{p.note && <span class="muted"> — {p.note}</span>}</li>)}</ul>
        </section>
      )}

      {b.nearby && b.nearby.length > 0 && (
        <section class="block">
          <h2>📍 Nearby & other interest</h2>
          <ul>{b.nearby.map((n) => <li>{n}</li>)}</ul>
        </section>
      )}

      {seeds.length > 0 && (
        <section class="block">
          <h2>🔗 Beta sources</h2>
          <p class="muted tiny">Links Shotgun reads to keep this dossier current.</p>
          <ul class="seeds">{seeds.map((s: any) => <li><a href={s.url} target="_blank" rel="noopener">{s.title || s.url}</a> {s.tag && <span class="mono muted">· {s.tag}</span>}</li>)}</ul>
        </section>
      )}

      <section class="block comments">
        <h2>💬 Comments {comments.length > 0 && <span class="muted">({comments.length})</span>}</h2>
        {comments.map((c: any) => (
          <div class="cmt"><span class="c-author">{c.author}</span> <span class="c-when muted">{fmtDate(c.created_at)}</span><p>{c.body}</p></div>
        ))}
        <form class="cmt-form" id="cmt-form" data-id={obj.id}>
          <input id="c-name" placeholder="Your name" />
          <textarea id="c-body" rows="2" placeholder="Beta, a tip, a question, a hello…" required></textarea>
          <div class="cmt-foot">
            <button class="btn" type="submit">Post comment</button>
            <p class="msg" id="c-msg"></p>
          </div>
        </form>
        <p class="muted tiny">Comments are reviewed before they show up.</p>
      </section>

      {fg.length > 0 && (
        <Fragment>
          <script type="application/json" id="fg-data" set:html={JSON.stringify(fg)}></script>
          <div id="fg-modal" class="fg-modal" hidden>
            <div class="fg-card">
              <button class="fg-close" type="button" aria-label="Close">✕</button>
              <div class="fg-body"></div>
            </div>
          </div>
        </Fragment>
      )}
    </div>
  </section>

  <script>
    document.getElementById('cmt-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLElement;
      const msg = document.getElementById('c-msg');
      const body = (document.getElementById('c-body') as HTMLTextAreaElement).value.trim();
      if (!body) return;
      msg.textContent = 'Posting…'; msg.className = 'msg';
      try {
        const r = await fetch('/api/comment', { method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target: 'objective', id: (f as HTMLElement).dataset.id, author: (document.getElementById('c-name') as HTMLInputElement).value, body }) });
        const j = await r.json();
        if (j.ok) { msg.textContent = '🙏 Posted — it shows once reviewed!'; msg.className = 'msg ok'; (document.getElementById('c-body') as HTMLTextAreaElement).value = ''; }
        else { msg.textContent = j.error || 'Try again.'; msg.className = 'msg err'; }
      } catch { msg.textContent = 'Network hiccup — try again.'; msg.className = 'msg err'; }
    });
  </script>

  <style>
    .comments .cmt { padding: .7rem .9rem; background: rgba(255,255,255,.03); border: 1px solid var(--border); border-radius: 10px; margin-bottom: .6rem; }
    .comments .c-author { font-weight: 700; } .comments .c-when { font-size: .75rem; margin-left: .4rem; }
    .comments .cmt p { margin: .3rem 0 0; color: var(--muted); }
    .cmt-form { display: grid; gap: .6rem; margin-top: .8rem; max-width: 34rem; }
    .cmt-form input, .cmt-form textarea { background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .65rem .8rem; font: inherit; }
    .cmt-foot { display: flex; align-items: center; gap: 1rem; }
    .cmt-form .msg { font-size: .85rem; margin: 0; } .cmt-form .msg.ok { color: var(--green); } .cmt-form .msg.err { color: var(--red); }
  </style>

  <style>
    .container.narrow { width: min(100% - 2.5rem, 800px); }
    .back { display: inline-block; margin-bottom: 1rem; font-size: .9rem; }
    .obj-head h1 { margin: 0 0 .6rem; }
    .obj-head .meta { display: flex; gap: .5rem; flex-wrap: wrap; align-items: center; margin-bottom: 1rem; }
    .obj-head .mono { font-family: var(--font-mono); font-size: .8rem; color: var(--muted); }
    .btn.gpx { display: inline-block; }
    .pending { text-align: center; display: grid; gap: .3rem; padding: 2rem; }
    .pending .big { font-size: 2.5rem; }
    .summary { font-size: 1.05rem; line-height: 1.6; margin: 1.2rem 0; }
    .glance { display: flex; gap: .5rem; flex-wrap: wrap; margin: 1rem 0 .4rem; }
    .g-chip { font-size: .8rem; padding: .35rem .7rem; border-radius: 999px; background: rgba(255,255,255,.05); border: 1px solid var(--border); }
    .photos { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: .6rem; margin: 1.2rem 0; }
    .photos figure { margin: 0; } .photos img { width: 100%; border-radius: 10px; display: block; }
    .photos figcaption { font-size: .78rem; color: var(--muted); margin-top: .3rem; }
    .emergency { margin-top: .6rem; } .tel { color: var(--green); font-weight: 700; }
    .block { margin-top: 1.8rem; padding-top: 1.2rem; border-top: 1px solid var(--border); }
    .block h2 { font-size: 1.15rem; margin: 0 0 .7rem; }
    .block p { margin: .4rem 0; }
    .block ul { margin: .4rem 0; padding-left: 1.2rem; display: grid; gap: .3rem; }
    .block.warn h2 { color: var(--amber); }
    .cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 600px) { .cols { grid-template-columns: 1fr; } }
    .routes { display: grid; gap: .6rem; }
    .route { padding: .7rem .9rem; background: linear-gradient(180deg, var(--panel), var(--panel-2)); border: 1px solid var(--border); border-radius: 10px; }
    .r-top { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
    .r-name { font-weight: 700; } .r-name a { color: var(--text); } .r-name a:hover { color: var(--green); }
    .r-grade { color: var(--green); font-size: .8rem; }
    .r-note { font-size: .9rem; margin-top: .2rem; }
    .cond-links { display: flex; gap: .5rem; flex-wrap: wrap; }
    .seeds a { color: var(--sky); }
  </style>
  <script>
    (() => {
      const el = document.getElementById('fg-data');
      const modal = document.getElementById('fg-modal');
      if (!el || !modal) return;
      const data = JSON.parse(el.textContent || '[]');
      const body = modal.querySelector('.fg-body');
      const EMOJI = { edible:'🍃', poisonous:'☠️', medicinal:'⚕️', wildlife:'🦌', snake:'🐍', insect:'🦟', landmark:'🪨' };
      const LABEL = { edible:'Edible', poisonous:'Poisonous — do not touch/eat', medicinal:'Medicinal', wildlife:'Wildlife', snake:'Venomous', insect:'Biting/stinging', landmark:'Landmark' };
      const esc = (s) => (s || '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
      const open = (i) => {
        const f = data[i]; if (!f || !body) return;
        body.innerHTML =
          (f.photo ? `<img class="fg-photo" src="${esc(f.photo)}" alt="${esc(f.name)}" loading="lazy">` : '') +
          `<div class="fg-kind kind-${esc(f.kind)}">${EMOJI[f.kind]||'•'} ${LABEL[f.kind]||''}</div>` +
          `<h3>${esc(f.name)}</h3>` +
          (f.note ? `<p>${esc(f.note)}</p>` : '') +
          (f.treat ? `<p class="fg-treat"><strong>🆘 What to do:</strong> ${esc(f.treat)}</p>` : '') +
          (f.url ? `<a class="btn ghost sm" href="${esc(f.url)}" target="_blank" rel="noopener">More ↗</a>` : '');
        modal.hidden = false;
      };
      document.querySelectorAll('.fg-chip').forEach((c) => c.addEventListener('click', () => open(Number(c.dataset.fg))));
      const close = () => { modal.hidden = true; };
      modal.querySelector('.fg-close')?.addEventListener('click', close);
      modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    })();
  </script>

  <style>
    .fg-chips { display: flex; flex-wrap: wrap; gap: .5rem; }
    .fg-chip { cursor: pointer; font-size: .85rem; font-weight: 600; padding: .4rem .75rem; border-radius: 999px; border: 1px solid var(--border-2); background: rgba(255,255,255,.04); color: var(--text); transition: all .15s; }
    .fg-chip:hover { border-color: var(--green); transform: translateY(-1px); }
    .fg-cam { font-size: .7rem; margin-left: .25rem; opacity: .65; }
    .fg-chip[data-kind="poisonous"], .fg-chip[data-kind="snake"] { border-color: rgba(251,113,133,.5); }
    .fg-chip[data-kind="edible"] { border-color: rgba(52,211,153,.45); }
    .fg-chip[data-kind="medicinal"] { border-color: rgba(56,189,248,.45); }
    .fg-modal { position: fixed; inset: 0; z-index: 2000; background: rgba(0,0,0,.62); display: grid; place-items: center; padding: 1rem; }
    .fg-modal[hidden] { display: none; }
    .fg-card { position: relative; background: var(--panel); border: 1px solid var(--border-2); border-radius: 14px; max-width: min(440px, 92vw); width: 100%; max-height: 90vh; overflow-y: auto; padding: 1.4rem; }
    .fg-close { position: absolute; top: .6rem; right: .7rem; background: transparent; border: none; color: var(--muted); font-size: 1.2rem; cursor: pointer; }
    .fg-body h3 { margin: .3rem 0 .5rem; }
    .fg-photo { display: block; width: 100%; max-width: 90vw; max-height: clamp(140px, 38vh, 300px); object-fit: contain; border-radius: 10px; margin-bottom: .8rem; background: rgba(0,0,0,.25); }
    .fg-kind { display: inline-block; font-size: .74rem; font-weight: 700; padding: .2rem .55rem; border-radius: 999px; background: rgba(255,255,255,.06); }
    .kind-poisonous, .kind-snake { color: var(--red); } .kind-edible { color: var(--green); } .kind-medicinal { color: var(--sky); }
    .fg-treat { color: var(--amber); }
  </style>
  <script>
    (() => {
      const list = document.getElementById('pre-check');
      if (!list) return;
      const key = 'dtours-check-' + (list.dataset.obj || '');
      let state = {};
      try { state = JSON.parse(localStorage.getItem(key) || '{}'); } catch {}
      list.querySelectorAll('input[type=checkbox]').forEach((cb) => {
        const i = cb.dataset.ci;
        cb.checked = !!state[i];
        cb.closest('li')?.classList.toggle('done', cb.checked);
        cb.addEventListener('change', () => {
          state[i] = cb.checked;
          cb.closest('li')?.classList.toggle('done', cb.checked);
          try { localStorage.setItem(key, JSON.stringify(state)); } catch {}
        });
      });
    })();
  </script>

  <style>
    .checklist .check { list-style: none; padding: 0; margin: .6rem 0 0; display: grid; gap: .4rem; }
    .checklist .check li { background: rgba(255,255,255,.03); border: 1px solid var(--border); border-radius: 9px; }
    .checklist .check label { display: flex; align-items: flex-start; gap: .6rem; padding: .55rem .7rem; cursor: pointer; font-size: .9rem; }
    .checklist .check input { margin-top: .15rem; width: 18px; height: 18px; flex: 0 0 auto; accent-color: var(--green); }
    .checklist .check li.done span { text-decoration: line-through; color: var(--muted); }
  </style>
</Base>
