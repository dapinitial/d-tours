---
import Base from '../layouts/Base.astro';
import ShareButton from '../components/ShareButton.astro';
import ConsideringClimbs from '../components/ConsideringClimbs.astro';
import { getStops, getObjectives, getProposedObjectives, getResources, getRendezvous } from '../lib/data';
const [stops, objectives, proposedObjectives, resources, confirmedRdv] = await Promise.all([
  getStops(), getObjectives(), getProposedObjectives(), getResources(), getRendezvous(undefined, 'confirmed'),
]);
const sev: Record<string, string> = { low: 'chip', med: 'chip amber', high: 'chip red' };
const logistics = resources.filter((r) => r.layer === 'logistics' || r.layer === 'life');

// Link each stop to its beta: a climb → its objective dossier; a town → its stop
// dossier; plus coords + a one-tap Google Maps directions link.
const objFor = (s: any) => {
  const hay = `${s.name} ${s.sub ?? ''}`.toLowerCase();
  return objectives.find((o) => {
    const key = o.name.toLowerCase().split(/[\s(/]/)[0];
    if (key.length <= 3) return false;
    // WORD-BOUNDARY match, not substring — else "south" (South Early Winter Spire)
    // false-matches "Southern" Rado. \b keeps whole-word matches only.
    return new RegExp(`\\b${key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\b`).test(hay);
  }) ?? null;
};
const mapsUrl = (s: any) => (s.lat != null && s.lng != null) ? `https://www.google.com/maps/dir/?api=1&destination=${s.lat},${s.lng}` : null;

const packing = [
  { emoji: '🧗', title: 'Alpine Hardware', items: ['Double rack to 3"', '60m half ropes', 'Alpine draws', 'Helmet', 'Nut tool + cordelette'] },
  { emoji: '🐻', title: 'Backcountry / Wildlife Safety', items: ['Bear spray on chest harness', 'Certified bear canister', 'Tire protection (porcupines!)', 'First-aid + SAM splint'] },
  { emoji: '⚡', title: 'Comms & Power', items: ['Starlink Mini + cables', 'EcoFlow + solar (charges e-bikes!)', 'inReach Mini (subscription on)', 'goTenna pair charged', 'Gaia GPS maps downloaded'] },
  { emoji: '🚐', title: 'Vehicle / Life', items: ['Offline maps downloaded', 'National Parks Pass', 'Wedding attire (Aug 1!)', 'SUPs + pump + PFDs', 'e-MTBs + rack + tools'] },
];

// Group the (already sort-ordered) objectives into trip-sequence areas for the climbs list.
const areaOf = (region = ''): string => {
  const r = region.toLowerCase();
  if (/cañon|shelf/.test(r)) return 'Shelf Road, CO';
  if (/eldorado/.test(r)) return 'Eldorado Canyon, CO';
  if (/rmnp|longs/.test(r)) return 'RMNP, CO';
  if (/wind river/.test(r)) return 'Wind River Range, WY';
  if (/city of rocks/.test(r)) return 'City of Rocks, ID';
  if (/bitterroot/.test(r)) return 'Bitterroots, ID/MT';
  if (/glacier/.test(r)) return 'Glacier NP, MT';
  if (/sawtooth/.test(r)) return 'Sawtooths, ID';
  if (/leavenworth|tumwater|stuart/.test(r)) return 'Leavenworth / Stuart Range, WA';
  if (/mazama|methow/.test(r)) return 'Mazama, WA';
  if (/washington pass/.test(r)) return 'Washington Pass, WA';
  if (/index/.test(r)) return 'Index, WA';
  if (/darrington/.test(r)) return 'Darrington, WA';
  if (/anacortes|fidalgo/.test(r)) return 'Mt. Erie, WA';
  if (/squamish/.test(r)) return 'Squamish, BC';
  return region;
};
const climbAreas: { area: string; climbs: typeof objectives }[] = [];
for (const o of objectives) {
  const a = areaOf(o.region);
  const last = climbAreas[climbAreas.length - 1];
  if (last && last.area === a) last.climbs.push(o);
  else climbAreas.push({ area: a, climbs: [o] });
}
---
<Base title="D-Tours · Trip Plan">
  <article class="plan container">
    <header class="plan-head">
      <div>
        <p class="eyebrow">🚐 D-Tours · Offline Beta</p>
        <h1>Austin → Squamish<br/>The Road Trip Mega-Loop</h1>
      </div>
      <div class="plan-actions print-only-hide">
        <ShareButton path="/plan" label="📲 Share my plan"
          text="Follow our Austin → Squamish climbing trip — I might be passing near you! Here's the route + dates:" />
        <a class="btn ghost" href="/packet">📦 Save offline</a>
        <button class="btn ghost" onclick="window.print()">🖨️ Print / PDF</button>
      </div>
    </header>

    <!-- ROUTE -->
    <h2>🗺️ Route sequence</h2>
    <ol class="route">
      {stops.map((s) => {
        const obj = objFor(s);
        const hasDoss = !!(s as any).dossier && Object.keys((s as any).dossier).length > 0;
        const maps = mapsUrl(s);
        return (
        <li class:list={{ hard: s.flex === 'hard', rdv: !!s.rendezvous }}>
          <span class="r-emoji">{s.emoji}</span>
          <div class="r-body">
            <div class="r-top">
              <span class="r-name">{s.name}</span>
              {s.date && <span class="r-date">{s.date}</span>}
            </div>
            {s.sub && <div class="r-sub">{s.sub}</div>}
            {s.rendezvous && <div class="r-rdv">🤝 {s.rendezvous}</div>}
            <div class="r-links">
              {obj && <a class="r-link climb" href={`/objectives/${obj.id}`}>🧗 {obj.grade} beta →</a>}
              {!obj && hasDoss && <a class="r-link town" href={`/stops/${s.id}`}>📋 town dossier →</a>}
              {!obj && !hasDoss && (s.lat != null) && <a class="r-link town" href={`/stops/${s.id}`}>📋 stop info →</a>}
              {maps && <a class="r-link" href={maps} target="_blank" rel="noopener">📍 directions</a>}
              {(s.lat != null && s.lng != null) && <span class="r-coord mono">{s.lat.toFixed(3)}, {s.lng.toFixed(3)}</span>}
            </div>
          </div>
        </li>
      ); })}
    </ol>

    <!-- RENDEZVOUS -->
    <section class="rdv-section print-only-hide">
      <h2>🤝 Catch us along the way</h2>
      {confirmedRdv.length > 0 && (
        <div class="rdv-list">
          {confirmedRdv.map((r: any) => (
            <div class="rdv">🤝 <strong>{r.name}</strong>{r.place && ` · ${r.place}`}{r.when_text && ` · ${r.when_text}`}{r.note && <span class="muted"> — {r.note}</span>}</div>
          ))}
        </div>
      )}
      <p class="muted">On our route and want to meet up? Drop it here — we'll confirm and it'll show up above.</p>
      <form class="rdv-form" id="rdv-form">
        <input id="rdv-name" placeholder="Your name" required />
        <input id="rdv-place" placeholder="Where? (town / near what)" />
        <input id="rdv-when" placeholder="When? (e.g. Aug 5)" />
        <input id="rdv-note" placeholder="Note (optional)" />
        <button class="btn" type="submit">🤝 Propose a meet-up</button>
        <p class="msg" id="rdv-msg"></p>
      </form>
    </section>

    <!-- CLIMBS IN TRIP ORDER -->
    <h2>🧗 Climbs, in trip order</h2>
    <p class="muted climbs-sub">North-and-westward from Texas — the line-up by area, in the sequence we'll hit them. Tap any for the full dossier.</p>
    <div class="climb-areas">
      {climbAreas.map((g, i) => (
        <div class="climb-area">
          <div class="ca-head"><span class="ca-num">{i + 1}</span><h3>{g.area}</h3><span class="ca-count">{g.climbs.length} climb{g.climbs.length === 1 ? '' : 's'}</span></div>
          <div class="ca-list">
            {g.climbs.map((o) => (
              <a class="ca-climb" href={`/objectives/${o.id}`}>
                <span class="ca-grade mono">{o.grade}</span>
                <span class="ca-name">{o.name}{(o.beta || o.gpx_url) && <span class="ca-doss" title="Dossier ready"> 📋</span>}</span>
                {o.day_type && <span class={`ca-day ${o.day_type}`} title={o.day_type === 'crag' ? 'Crag · WFH-friendly' : 'Weekend alpine'}>{o.day_type === 'crag' ? '🪨' : '⛰️'}</span>}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <ConsideringClimbs objectives={proposedObjectives} />

    <!-- LOGISTICS -->
    <h2>🏕️ Logistics, friends &amp; basecamps</h2>
    <div class="grid cols-3">
      {logistics.map((r) => (
        <div class="card"><h3><span class="emoji">{r.emoji}</span>{r.title}</h3><p class="muted">{r.body}</p></div>
      ))}
    </div>

    <!-- PACKING -->
    <h2>🎒 Packing &amp; gear checklist</h2>
    <div class="grid cols-4">
      {packing.map((col) => (
        <div class="card">
          <h3><span class="emoji">{col.emoji}</span>{col.title}</h3>
          <ul class="check">
            {col.items.map((it) => <li><span class="box"></span>{it}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </article>

  <script>
    // whole objective rows → dossier
    document.querySelectorAll('tr.clickable[data-href]').forEach((tr) => {
      tr.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a, button')) return;
        location.href = (tr as HTMLElement).dataset.href!;
      });
    });

    document.getElementById('rdv-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = document.getElementById('rdv-msg');
      const g = (id) => (document.getElementById(id) as HTMLInputElement).value.trim();
      const name = g('rdv-name');
      if (!name) { msg.textContent = 'Add your name first.'; msg.className = 'msg err'; return; }
      msg.textContent = 'Sending…'; msg.className = 'msg';
      try {
        const r = await fetch('/api/rendezvous', { method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, place: g('rdv-place'), when_text: g('rdv-when'), note: g('rdv-note') }) });
        const j = await r.json();
        if (j.ok) { msg.textContent = '🤝 Sent — they\'ll confirm if it works!'; msg.className = 'msg ok'; (e.target as HTMLFormElement).reset(); }
        else { msg.textContent = j.error || 'Try again.'; msg.className = 'msg err'; }
      } catch { msg.textContent = 'Network hiccup — try again.'; msg.className = 'msg err'; }
    });
  </script>
</Base>

<style>
  .plan { padding: 2.5rem 0 4rem; }
  .plan-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 1.5rem; margin-bottom: 2.5rem; }
  .plan h2 { margin-top: 3rem; padding-top: 1.2rem; border-top: 1px solid var(--border); }
  .route { list-style: none; counter-reset: step; padding: 0; display: grid; gap: .55rem; }
  .route li { counter-increment: step; display: flex; align-items: flex-start; gap: .6rem; padding: .7rem .85rem; background: var(--panel); border: 1px solid var(--border); border-radius: 10px; }
  .route li::before { content: counter(step); font-family: var(--font-mono); font-size: .72rem; color: var(--green); min-width: 1.4em; padding-top: .15rem; }
  .route li.hard { border-color: rgba(251,113,133,.4); }
  .route li.rdv { border-color: rgba(56,189,248,.4); }
  .r-emoji { font-size: 1.2rem; padding-top: .05rem; }
  .r-body { flex: 1; min-width: 0; }
  .r-top { display: flex; align-items: baseline; gap: .6rem; flex-wrap: wrap; }
  .r-name { font-weight: 700; }
  .r-date { font-family: var(--font-mono); font-size: .72rem; color: var(--green); }
  .r-sub { color: var(--muted); font-size: .85rem; margin-top: .1rem; }
  .r-rdv { font-size: .82rem; color: var(--sky, #38bdf8); margin-top: .2rem; }
  .r-links { display: flex; align-items: center; gap: .5rem .9rem; flex-wrap: wrap; margin-top: .45rem; }
  .r-link { font-size: .8rem; font-weight: 600; text-decoration: none; color: var(--text); border-bottom: 1px dashed var(--border-2); }
  .r-link.climb { color: var(--green); border-color: rgba(52,211,153,.4); }
  .r-link.town { color: var(--amber, #fbbf24); border-color: rgba(251,191,36,.35); }
  .r-link:hover { border-style: solid; }
  .r-coord { font-size: .68rem; color: var(--faint); }
  ul.check { list-style: none; padding: 0; margin: .5rem 0 0; display: grid; gap: .5rem; }
  ul.check li { display: flex; align-items: center; gap: .55rem; font-size: .9rem; }
  .box { width: 15px; height: 15px; border: 1.5px solid var(--border-2); border-radius: 4px; flex: 0 0 auto; }
  .obj-link { color: var(--text); border-bottom: 1px dotted var(--border-2); }
  .obj-link:hover { color: var(--green); border-color: var(--green); }
  .climbs-sub { margin: -.6rem 0 1.1rem; font-size: .92rem; }
  .climb-areas { display: grid; gap: .9rem; }
  .climb-area { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: linear-gradient(180deg, var(--panel), var(--panel-2)); }
  .ca-head { display: flex; align-items: center; gap: .6rem; padding: .6rem .9rem; border-bottom: 1px solid var(--border); }
  .ca-num { width: 1.5rem; height: 1.5rem; flex: none; display: grid; place-items: center; background: rgba(52,211,153,.12); color: var(--green); border-radius: 999px; font-family: var(--font-mono); font-size: .78rem; font-weight: 700; }
  .ca-head h3 { margin: 0; font-size: 1rem; flex: 1; }
  .ca-count { font-size: .72rem; color: var(--muted); font-family: var(--font-mono); }
  .ca-list { display: grid; }
  .ca-climb { display: flex; align-items: center; gap: .7rem; padding: .55rem .9rem; color: var(--text); text-decoration: none; border-top: 1px solid var(--border); }
  .ca-list .ca-climb:first-child { border-top: 0; }
  .ca-climb:hover { background: rgba(52,211,153,.06); }
  .ca-grade { font-size: .76rem; color: var(--muted); min-width: 6.5rem; white-space: nowrap; }
  .ca-name { flex: 1; min-width: 0; font-weight: 600; font-size: .9rem; }
  .ca-doss { font-size: .8rem; }
  .ca-day { font-size: .9rem; }
  @media (max-width: 560px) { .ca-grade { min-width: 0; font-size: .7rem; } }

  .rdv-section { margin-top: 3rem; padding-top: 1.2rem; border-top: 1px solid var(--border); }
  .rdv-list { display: grid; gap: .5rem; margin: .8rem 0 1.2rem; }
  .rdv { padding: .7rem .9rem; background: rgba(52,211,153,.07); border: 1px solid rgba(52,211,153,.25); border-radius: 10px; }
  .rdv-form { display: grid; gap: .6rem; max-width: 30rem; }
  .rdv-form input { background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .7rem .85rem; font: inherit; }
  .rdv-form .msg { font-size: .85rem; margin: 0; min-height: 1.1em; }
  .rdv-form .msg.ok { color: var(--green); } .rdv-form .msg.err { color: var(--red); }

  /* ════════ PRINT / PDF — Letter, light bg, crisp black, no awkward breaks ════════ */
  @media print {
    @page { size: letter; margin: 0.6in; }
    :root {
      --bg:#fff; --bg-2:#fff; --panel:#fff; --panel-2:#fafafa;
      --border:#cbd5e1; --border-2:#94a3b8;
      --text:#0b1220; --muted:#334155; --faint:#64748b; --green:#15803d; --green-2:#166534;
    }
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    body { background:#fff !important; color:#000 !important; font-size: 11pt; }
    .site-header, .site-footer, .print-only-hide, .cursor-dot, .cursor-ring { display: none !important; }
    [data-reveal] { opacity: 1 !important; transform: none !important; }
    h1, h2, h3 { color:#000 !important; break-after: avoid; break-inside: avoid; }
    h2 { font-size: 15pt; border-top: 1px solid #cbd5e1; }
    .card, .route li, table, tr, .table-wrap { break-inside: avoid; }
    thead { display: table-header-group; }
    table.data { min-width: 0; font-size: 9.5pt; }
    a { color:#000 !important; text-decoration: none; }
    .chip { border:1px solid #999 !important; color:#000 !important; background:#fff !important; }
    .grid.cols-4 { grid-template-columns: repeat(2, 1fr); }
    .box { border-color:#333 !important; }
    .plan h2 { margin-top: 1.4rem; }
  }
</style>
