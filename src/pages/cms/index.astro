---
import Base from '../../layouts/Base.astro';
import { getPosts, getStops, getSuggestions, isMock } from '../../lib/data';
const user = Astro.locals.user;
const tid = Astro.locals.tenantId;
const [posts, stops, fanSuggestions] = await Promise.all([
  getPosts({ tenantId: tid }), getStops(tid), getSuggestions(tid, 'pending'),
]);
const queued = posts.filter((p) => !p.published_at).length;
const proposals = stops
  .filter((s) => s.status === 'proposed' || s.status === 'suggested')
  .sort((a, b) => a.order - b.order);
---
<Base title="D-Tours · CMS">
  <section>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🗂️ Control</p>
        <h2>CMS — run the trip from anywhere</h2>
        <p>Phone or laptop. Post by typing here, or text Shotgun and it posts for you. {isMock && <strong>(mock mode — wire Supabase to persist)</strong>}.</p>
      </div>

      {user && (
        <div class="user-bar">
          <span class="muted">🔐 Signed in as <strong>{user.name ?? user.email}</strong></span>
          <form method="POST" action="/auth/signout"><button class="btn ghost sm" type="submit">Sign out</button></form>
        </div>
      )}

      <div class="stats grid cols-4">
        <div class="stat card"><div class="n">{posts.length}</div><div class="muted">posts</div></div>
        <div class="stat card"><div class="n">{queued}</div><div class="muted">queued (Tier 1)</div></div>
        <div class="stat card"><div class="n">{stops.length}</div><div class="muted">stops</div></div>
        <div class="stat card"><div class="n mono">{isMock ? 'MOCK' : 'LIVE'}</div><div class="muted">data source</div></div>
      </div>

      <div class="quick-links">
        <a class="btn ghost sm" href="/cms/itinerary">🗺️ Edit itinerary</a>
        <a class="btn ghost sm" href="/cms/sources">📡 Sources &amp; beta</a>
        <a class="btn ghost sm" href="/cms/soundtrack">🎶 Soundtrack</a>
      </div>

      <div class="grid cols-2 editor-row">
        <div class="card">
          <h3>✍️ New post</h3>
          <form class="composer" id="composer" onsubmit="return false">
            <input id="post-title" type="text" placeholder="Title — e.g. 'Topped out the Spearhead'" />
            <textarea id="post-body" rows="4" placeholder="What happened out there?"></textarea>
            <input id="post-video" type="url" placeholder="📹 Video link (YouTube / Vimeo — optional)" />
            <div id="thumbs" class="thumbs"></div>
            <div class="composer-foot">
              <label class="file">📷 Add photos<input id="post-photos" type="file" accept="image/*" multiple hidden /></label>
              <div class="actions">
                <button class="btn ghost" id="post-queue">Queue (Tier 1)</button>
                <button class="btn" id="post-publish">Publish</button>
              </div>
            </div>
            <p class="msg" id="post-msg"></p>
          </form>
          <p class="muted tiny">Photos upload to Supabase Storage; video links embed. Publish goes live now; Queue holds for the next signal.</p>
        </div>

        <div class="card">
          <h3>🤖 Shotgun controls</h3>
          <div class="ctl"><span>Daily digest</span><button class="btn ghost sm" id="run-digest">Send now</button></div>
          <div class="ctl"><span>D-Tours look-ahead</span><button class="btn ghost sm" id="run-dtours">Scan corridor</button></div>
          <div class="ctl"><span>MapShare position</span><button class="btn ghost sm" id="run-map">Refresh dot</button></div>
          <pre id="ctl-out" class="out muted">Output appears here…</pre>
        </div>
      </div>

      <div class="card proposals">
        <h3>🌀 D-Tours proposals — Shotgun found these on the fly</h3>
        <p class="muted tiny">Approve to drop it into the live itinerary (no deploy — instant). This is the same action a "YES" text triggers.</p>
        {proposals.length === 0 && <p class="muted">Nothing staged right now.</p>}
        <div class="prop-list">
          {proposals.map((s) => (
            <div class="prop" data-id={s.id}>
              <span class="p-emoji">{s.emoji}</span>
              <div class="p-meta">
                <div class="p-name">{s.name} <span class={`tag ${s.status}`}>{s.status}</span></div>
                <div class="muted p-sub">{s.sub}{s.off_route_mi != null && ` · ${s.off_route_mi}mi · ~${s.time_cost_min}min`}{s.note && ` · ${s.note}`}</div>
              </div>
              <div class="p-actions">
                <button class="btn sm approve" data-id={s.id}>✓ Add</button>
                <button class="btn ghost sm decline" data-id={s.id}>✕</button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="card proposals">
        <h3>📨 Follower suggestions {fanSuggestions.length > 0 && <span class="tag suggested">{fanSuggestions.length}</span>}</h3>
        <p class="muted tiny">Detours your crew sent in. Approve → drops onto the itinerary as a proposed stop.</p>
        {fanSuggestions.length === 0 && <p class="muted">No new follower suggestions.</p>}
        <div class="prop-list">
          {fanSuggestions.map((s: any) => (
            <div class="prop" data-fan={s.id}>
              <span class="p-emoji">💡</span>
              <div class="p-meta">
                <div class="p-name">{s.title}</div>
                <div class="muted p-sub">{[s.location, s.note].filter(Boolean).join(' · ')} — {s.suggested_by}</div>
              </div>
              <div class="p-actions">
                <button class="btn sm fan-approve" data-id={s.id}>✓ Add</button>
                <button class="btn ghost sm fan-decline" data-id={s.id}>✕</button>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</Base>

<script>
  const out = document.getElementById('ctl-out');
  const hit = async (url, label) => {
    out.textContent = `${label}…`;
    try { const r = await fetch(url, { method: 'POST' }); out.textContent = JSON.stringify(await r.json(), null, 2); }
    catch (e) { out.textContent = `error: ${e}`; }
  };
  document.getElementById('run-digest')?.addEventListener('click', () => hit('/api/digest', 'Composing digest'));
  document.getElementById('run-dtours')?.addEventListener('click', () => hit('/api/dtours', 'Scanning corridor'));
  document.getElementById('run-map')?.addEventListener('click', () => hit('/api/mapshare', 'Polling MapShare'));

  // approve / decline staged proposals → mutate itinerary on the fly
  const act = async (id, action) => {
    const row = document.querySelector(`.prop[data-id="${id}"]`);
    if (row) row.style.opacity = '0.4';
    try {
      const r = await fetch('/api/itinerary', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action, id }) });
      const j = await r.json();
      if (row) { row.style.transition = 'all .4s'; row.style.height = '0'; setTimeout(() => row.remove(), 400); }
      if (out) out.textContent = `${action === 'promote' ? 'Added to itinerary' : 'Declined'}: ${id}\n${JSON.stringify(j)}`;
    } catch (e) { if (out) out.textContent = `error: ${e}`; }
  };
  document.querySelectorAll('.approve').forEach((b) => b.addEventListener('click', () => act(b.dataset.id, 'promote')));
  document.querySelectorAll('.decline').forEach((b) => b.addEventListener('click', () => act(b.dataset.id, 'decline')));

  // follower detour suggestions → approve (stages a proposed stop) / decline
  const fanAct = async (id, action) => {
    const row = document.querySelector(`.prop[data-fan="${id}"]`);
    if (row) row.style.opacity = '0.4';
    try {
      const r = await fetch('/api/suggest', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action, id }) });
      const j = await r.json();
      if (j.ok && row) { row.style.transition = 'all .4s'; row.style.height = '0'; setTimeout(() => row.remove(), 400); }
      if (out) out.textContent = `${action === 'approve' ? 'Staged to itinerary' : 'Declined'}: ${id}\n${JSON.stringify(j)}`;
    } catch (e) { if (out) out.textContent = `error: ${e}`; if (row) row.style.opacity = '1'; }
  };
  document.querySelectorAll('.fan-approve').forEach((b) => b.addEventListener('click', () => fanAct(b.dataset.id, 'approve')));
  document.querySelectorAll('.fan-decline').forEach((b) => b.addEventListener('click', () => fanAct(b.dataset.id, 'decline')));

  // ── post composer: upload photos → collect URLs → create post ──
  const uploaded = [];            // public URLs of uploaded photos
  const thumbs = document.getElementById('thumbs');
  const pmsg = document.getElementById('post-msg');
  const setMsg = (m, err = false) => { if (pmsg) { pmsg.textContent = m; pmsg.className = 'msg' + (err ? ' err' : ' ok'); } };

  document.getElementById('post-photos')?.addEventListener('change', async (e) => {
    const files = [...e.target.files];
    for (const file of files) {
      const ph = document.createElement('div'); ph.className = 'thumb loading'; ph.textContent = '⏳';
      thumbs.appendChild(ph);
      const fd = new FormData(); fd.append('file', file);
      try {
        const r = await fetch('/api/upload', { method: 'POST', body: fd });
        const j = await r.json();
        if (j.ok && j.url) { uploaded.push(j.url); ph.className = 'thumb'; ph.style.backgroundImage = `url(${j.url})`; ph.textContent = ''; }
        else { ph.className = 'thumb err'; ph.textContent = '⚠️'; setMsg(j.error || 'Upload failed', true); }
      } catch { ph.className = 'thumb err'; ph.textContent = '⚠️'; setMsg('Upload failed', true); }
    }
    e.target.value = '';
  });

  const submitPost = async (published) => {
    const title = document.getElementById('post-title').value.trim();
    const body = document.getElementById('post-body').value.trim();
    const video = document.getElementById('post-video').value.trim();
    const media = [...uploaded, ...(video ? [video] : [])];
    if (!title && !body && !media.length) { setMsg('Add a title, some words, or a photo.', true); return; }
    setMsg('Saving…');
    try {
      const r = await fetch('/api/post', { method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, body, media, published }) });
      const j = await r.json();
      if (j.ok) { setMsg(published ? '✅ Published!' : '🕒 Queued.'); setTimeout(() => location.reload(), 800); }
      else setMsg(j.error || 'Failed', true);
    } catch { setMsg('Network hiccup — try again.', true); }
  };
  document.getElementById('post-publish')?.addEventListener('click', () => submitPost(true));
  document.getElementById('post-queue')?.addEventListener('click', () => submitPost(false));
</script>

<style>
  .user-bar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .7rem 1rem; background: rgba(52,211,153,.07); border: 1px solid rgba(52,211,153,.25); border-radius: 10px; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .user-bar form { margin: 0; }
  .stats { margin-bottom: 1.5rem; }
  .quick-links { margin-bottom: 1.5rem; display: flex; gap: .5rem; flex-wrap: wrap; }
  .stat { text-align: center; }
  .stat .n { font-size: 2rem; font-weight: 800; color: var(--green); }
  .editor-row { align-items: stretch; margin-bottom: 1.5rem; }
  .editor-row > .card { display: flex; flex-direction: column; }
  .composer { display: grid; gap: .7rem; }
  .composer input, .composer textarea { width: 100%; background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .7rem .85rem; font: inherit; }
  .composer-foot { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .file { cursor: pointer; color: var(--muted); font-size: .9rem; }
  .file:hover { color: var(--green); }
  .actions { display: flex; gap: .5rem; }
  .thumbs { display: flex; gap: .5rem; flex-wrap: wrap; }
  .thumbs:empty { display: none; }
  .thumb { width: 64px; height: 64px; border-radius: 8px; background: var(--bg-2) center/cover no-repeat; border: 1px solid var(--border); display: grid; place-items: center; font-size: 1.1rem; }
  .thumb.loading { animation: pulse 1s infinite; }
  .thumb.err { border-color: var(--red); }
  @keyframes pulse { 50% { opacity: .5; } }
  .msg { font-size: .85rem; margin: 0; min-height: 1.1em; }
  .msg.ok { color: var(--green); } .msg.err { color: var(--red); }
  .tiny { font-size: .78rem; margin-top: .8rem; }
  .ctl { display: flex; justify-content: space-between; align-items: center; padding: .6rem 0; border-bottom: 1px solid var(--border); }
  .ctl:last-of-type { border-bottom: 0; }
  .btn.sm { padding: .45rem .9rem; font-size: .85rem; }
  .out { margin-top: 1rem; background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; padding: .8rem; font-size: .78rem; white-space: pre-wrap; max-height: 220px; overflow: auto; }
  .next ul { margin: .5rem 0 0; padding-left: 1.2rem; color: var(--muted); }
  .next li { margin: .3rem 0; }
  code { font-family: var(--font-mono); color: var(--green); }
  .proposals { margin-bottom: 1.5rem; }
  .prop-list { display: grid; gap: .6rem; margin-top: 1rem; }
  .prop { display: flex; align-items: center; gap: .8rem; padding: .7rem .85rem; background: rgba(255,255,255,.025); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .p-emoji { font-size: 1.4rem; }
  .p-meta { flex: 1; min-width: 0; }
  .p-name { font-weight: 700; }
  .p-sub { font-size: .82rem; }
  .p-actions { display: flex; gap: .4rem; flex: 0 0 auto; }
  .tag { font-family: var(--font-mono); font-size: .58rem; text-transform: uppercase; letter-spacing: .08em; padding: .12rem .4rem; border-radius: 999px; border: 1px dashed; margin-left: .3rem; }
  .tag.proposed { color: var(--sky); border-color: rgba(56,189,248,.5); }
  .tag.suggested { color: var(--amber); border-color: rgba(251,191,36,.5); }
</style>
