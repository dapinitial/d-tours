---
import Base from '../../layouts/Base.astro';
import { getObjectives, getSources } from '../../lib/data';
const tid = Astro.locals.tenantId;
const [objectives, sources] = await Promise.all([getObjectives(tid, { includeProposed: true }), getSources(tid)]);
const seedsFor = (oid: string) => sources.filter((s: any) => s.objective_id === oid);
const sevs = ['low', 'med', 'high'];
const TAGS = ['mountain-project', 'wta', 'summitpost', 'alltrails', 'gpx', 'forecast', 'avalanche', 'general'];
const needsResearch = objectives.filter((o) => !o.beta).length;
const proposed = objectives.filter((o) => o.status === 'proposed');
---
<Base title="D-Tours · Edit Objectives">
  <section>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🧗 Objectives</p>
        <h2>Climbing objectives & beta</h2>
        <p>Add an objective, then <strong>seed it with links</strong> (Mountain Project, WTA, a GPX, a trip report). Shotgun reads those, researches, and compiles the dossier — visible at <code>/objectives/&lt;id&gt;</code>.</p>
        <a href="/cms" class="muted back">← back to CMS</a>
        {needsResearch > 0 && <p class="research-note">🔍 <strong>{needsResearch}</strong> objective{needsResearch === 1 ? '' : 's'} awaiting a Shotgun dossier pass.</p>}
      </div>

      {proposed.length > 0 && (
        <div class="card proposed-card">
          <h3>🧭 Shotgun's proposed alternatives <span class="tag suggested">{proposed.length}</span></h3>
          <p class="muted tiny">Scouted climbs (a pivot if one's too hard/easy). Review the dossier, then add it to your trip.</p>
          <div class="prop-list">
            {proposed.map((o) => (
              <div class="prop" data-prop={o.id}>
                <span class="p-emoji">🧗</span>
                <div class="p-meta">
                  <div class="p-name"><a href={`/objectives/${o.id}`} target="_blank">{o.name}</a> <span class="muted tiny">{o.grade} · {o.region}</span></div>
                  {o.note && <div class="muted p-sub">{o.note}</div>}
                </div>
                <div class="p-actions">
                  <button class="btn sm prop-add" data-id={o.id}>✓ Add to trip</button>
                  <button class="btn ghost sm prop-del" data-id={o.id}>✕</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- add objective -->
      <div class="card add-card">
        <h3>＋ Add an objective</h3>
        <div class="composer">
          <input id="o-name" placeholder="Name — e.g. Mt. Reynolds, Swiftsure Ridge" />
          <div class="composer-row">
            <input id="o-region" placeholder="Region (Glacier NP, MT)" />
            <input id="o-grade" placeholder="Grade (5.4 Alpine)" />
          </div>
          <div class="composer-row">
            <input id="o-commit" placeholder="Commitment (Full day / airy ridge)" />
            <input id="o-disc" placeholder="Discipline (alpine)" />
          </div>
          <div class="composer-row">
            <input id="o-hazard" placeholder="Key hazard (Choss & grizzlies)" />
            <select id="o-sev">{sevs.map((s) => <option value={s} selected={s === 'med'}>{s}</option>)}</select>
          </div>
          <div class="composer-foot">
            <span class="muted tiny">Shotgun fills the dossier on its next pass.</span>
            <button id="add-obj" class="btn">Add objective</button>
          </div>
        </div>
      </div>

      <!-- objectives -->
      <div id="rows" class="rows">
        {objectives.map((o) => {
          const seeds = seedsFor(o.id);
          return (
            <div class="obj card" data-id={o.id}>
              <div class="obj-top">
                <input class="o-name" data-field="name" value={o.name} placeholder="Name" />
                <span class="status">{o.beta ? <a href={`/objectives/${o.id}`} target="_blank" class="ready">📋 dossier</a> : <span class="pending">🔍 needs research</span>}</span>
                <button class="del" title="Delete" aria-label="delete">🗑️</button>
              </div>
              <div class="meta-row">
                <input class="sm" data-field="region" value={o.region ?? ''} placeholder="Region" />
                <input class="sm" data-field="grade" value={o.grade ?? ''} placeholder="Grade" />
                <input class="sm" data-field="discipline" value={o.discipline ?? ''} placeholder="Discipline" />
                <select class="sm" data-field="severity">{sevs.map((s) => <option value={s} selected={o.severity === s}>{s}</option>)}</select>
              </div>
              <div class="meta-row">
                <input class="wide" data-field="commitment" value={o.commitment ?? ''} placeholder="Commitment" />
                <input class="wide" data-field="hazard" value={o.hazard ?? ''} placeholder="Key hazard" />
              </div>

              <div class="seeds">
                <div class="seeds-label">🔗 Seed links <span class="muted">— what Shotgun researches from</span></div>
                {seeds.length > 0 && (
                  <ul class="seed-list">
                    {seeds.map((s: any) => <li><a href={s.url} target="_blank" rel="noopener">{s.title || s.url}</a> {s.tag && <span class="mono muted">· {s.tag}</span>} <span class={`st ${s.status}`}>{s.status === 'enriched' ? '✓' : '⏳'}</span></li>)}
                  </ul>
                )}
                <div class="seed-add">
                  <input class="s-url" type="url" placeholder="https://… (MP / WTA / GPX / trip report)" />
                  <select class="s-tag">{TAGS.map((t) => <option value={t}>{t}</option>)}</select>
                  <button class="btn ghost sm seed-btn">＋ Seed</button>
                </div>
              </div>
            </div>
          );
        })}
      </div>
      <div id="toast" class="toast"></div>
    </div>
  </section>

  <script>
    const toastEl = document.getElementById('toast');
    const toast = (m, err = false) => { toastEl.textContent = m; toastEl.className = 'toast show' + (err ? ' err' : ''); setTimeout(() => toastEl.className = 'toast', 1600); };
    const post = async (url, body) => { const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }); const j = await r.json(); if (!j.ok) toast(j.error || 'Failed', true); return j; };
    const rid = () => (crypto.randomUUID ? crypto.randomUUID() : 'o-' + Math.random().toString(36).slice(2));

    // inline edits
    document.querySelectorAll('.obj [data-field]').forEach((inp) => inp.addEventListener('change', async () => {
      const card = inp.closest('.obj');
      const j = await post('/api/objectives', { action: 'update', id: card.dataset.id, obj: { [inp.dataset.field]: inp.value } });
      if (j.ok) toast('Saved ✓');
    }));
    // delete
    document.querySelectorAll('.obj .del').forEach((b) => b.addEventListener('click', async () => {
      const card = b.closest('.obj');
      if (!confirm('Delete this objective?')) return;
      const j = await post('/api/objectives', { action: 'remove', id: card.dataset.id });
      if (j.ok) { card.remove(); toast('Deleted'); }
    }));
    // seed a link → pins to this objective, feeds Shotgun
    document.querySelectorAll('.obj .seed-btn').forEach((b) => b.addEventListener('click', async () => {
      const card = b.closest('.obj');
      const url = card.querySelector('.s-url').value.trim();
      if (!url) { toast('Paste a link', true); return; }
      const tag = card.querySelector('.s-tag').value;
      const j = await post('/api/sources', { action: 'add', source: { id: rid(), url, tag, objective_id: card.dataset.id } });
      if (j.ok) { toast('Seeded ✓ — Shotgun will read it'); location.reload(); }
    }));
    // add objective
    document.getElementById('add-obj').addEventListener('click', async () => {
      const v = (id) => (document.getElementById(id)).value.trim();
      const name = v('o-name'); if (!name) { toast('Name it first', true); return; }
      const j = await post('/api/objectives', { action: 'add', obj: {
        id: rid(), name, region: v('o-region'), grade: v('o-grade'), commitment: v('o-commit'),
        discipline: v('o-disc'), hazard: v('o-hazard'), severity: (document.getElementById('o-sev')).value,
      }});
      if (j.ok) location.reload();
    });

    // proposed alternatives → promote (add to trip) / dismiss
    document.querySelectorAll('.prop-add').forEach((b) => b.addEventListener('click', async () => {
      const j = await post('/api/objectives', { action: 'promote', id: b.dataset.id });
      if (j.ok) { toast('Added to your trip ✓'); location.reload(); }
    }));
    document.querySelectorAll('.prop-del').forEach((b) => b.addEventListener('click', async () => {
      if (!confirm('Dismiss this proposed climb?')) return;
      const j = await post('/api/objectives', { action: 'remove', id: b.dataset.id });
      if (j.ok) { b.closest('.prop')?.remove(); toast('Dismissed'); }
    }));
  </script>

  <style>
    .back { display: inline-block; margin-top: .5rem; font-size: .9rem; }
    .research-note { margin-top: .7rem; color: var(--amber); font-size: .9rem; }
    .add-card { margin-bottom: 1.5rem; }
    .proposed-card { margin-bottom: 1.5rem; border-color: rgba(56,189,248,.35); background: linear-gradient(180deg, rgba(56,189,248,.07), var(--panel)); }
    .tag { font-size: .7rem; padding: .1rem .5rem; border-radius: 999px; }
    .tag.suggested { background: rgba(56,189,248,.2); color: var(--sky); }
    .prop-list { display: grid; gap: .6rem; margin-top: .8rem; }
    .prop { display: flex; align-items: center; gap: .7rem; padding: .6rem .7rem; background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; }
    .p-emoji { font-size: 1.2rem; } .p-meta { flex: 1; } .p-name a { color: var(--text); } .p-name a:hover { color: var(--green); }
    .p-sub { font-size: .82rem; margin-top: .15rem; }
    .p-actions { display: flex; gap: .4rem; flex-wrap: wrap; }
    .composer { display: grid; gap: .6rem; }
    .composer input, .composer select { width: 100%; background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .65rem .8rem; font: inherit; }
    .composer-row { display: flex; gap: .6rem; }
    .composer-row > * { flex: 1; }
    .composer-foot { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .rows { display: grid; gap: .9rem; }
    .obj { display: grid; gap: .55rem; }
    .obj-top { display: flex; align-items: center; gap: .6rem; }
    .o-name { flex: 1; font-weight: 700; font-size: 1.05rem; }
    .status { font-size: .82rem; white-space: nowrap; }
    .status .ready { color: var(--green); text-decoration: none; }
    .status .pending { color: var(--amber); }
    .del { background: transparent; border: 1px solid var(--border); border-radius: 8px; cursor: pointer; padding: .35rem .5rem; }
    .del:hover { border-color: var(--red); }
    .obj input, .obj select { background: var(--bg-2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); padding: .5rem .6rem; font: inherit; }
    .meta-row { display: flex; gap: .5rem; flex-wrap: wrap; }
    .meta-row .sm { flex: 1; min-width: 7rem; font-size: .85rem; }
    .meta-row .wide { flex: 1; min-width: 12rem; font-size: .85rem; }
    .seeds { margin-top: .3rem; padding-top: .6rem; border-top: 1px dashed var(--border); }
    .seeds-label { font-size: .82rem; font-weight: 600; margin-bottom: .4rem; }
    .seed-list { list-style: none; padding: 0; margin: 0 0 .5rem; display: grid; gap: .25rem; font-size: .85rem; }
    .seed-list a { color: var(--sky); }
    .st.enriched { color: var(--green); }
    .seed-add { display: flex; gap: .4rem; flex-wrap: wrap; }
    .seed-add .s-url { flex: 1; min-width: 12rem; font-size: .85rem; }
    .toast { position: fixed; bottom: 1.2rem; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--green); color: #06210f; padding: .6rem 1.1rem; border-radius: 999px; font-weight: 700; opacity: 0; pointer-events: none; transition: all .3s var(--ease); z-index: 300; }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.err { background: var(--red); color: #2a0a0f; }
  </style>
</Base>
