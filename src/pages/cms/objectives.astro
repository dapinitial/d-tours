---
import Base from '../../layouts/Base.astro';
import { getObjectives, getSources, getDeferredObjectives } from '../../lib/data';
const tid = Astro.locals.tenantId;
const [objectives, sources, deferred] = await Promise.all([getObjectives(tid, { includeProposed: true }), getSources(tid), getDeferredObjectives(tid)]);
const seedsFor = (oid: string) => sources.filter((s: any) => s.objective_id === oid);
const sevs = ['low', 'med', 'high'];
const days: [string, string][] = [['', '—'], ['crag', '🪨 Crag · WFH'], ['alpine', '⛰️ Weekend alpine']];
const TAGS = ['mountain-project', 'wta', 'summitpost', 'alltrails', 'gpx', 'forecast', 'avalanche', 'general'];
const needsResearch = objectives.filter((o) => !o.beta).length;
const proposed = objectives.filter((o) => o.status === 'proposed');
---
<Base title="D-Tours · Edit Objectives">
  <section>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">🧗 Objectives</p>
        <h2>Climbing objectives & beta</h2>
        <p>Add an objective, then <strong>seed it with links</strong> (Mountain Project, WTA, a GPX, a trip report). Shotgun reads those, researches, and compiles the dossier — visible at <code>/objectives/&lt;id&gt;</code>.</p>
        <a href="/cms" class="muted back">← back to CMS</a>
        {needsResearch > 0 && <p class="research-note">🔍 <strong>{needsResearch}</strong> objective{needsResearch === 1 ? '' : 's'} awaiting a Shotgun dossier pass.</p>}
      </div>

      <div class="view-toggle">
        <button id="view-edit" class="vt active" type="button">🗂️ Edit &amp; beta</button>
        <button id="view-order" class="vt" type="button">🔀 Reorder route ({objectives.length})</button>
      </div>

      <div id="order-list" class="order-list" hidden>
        <p class="muted tiny ord-hint">Drag ⠿ to set the order you'll hit these on the trip (top = first). Saves automatically.</p>
        {objectives.map((o) => (
          <div class="ord-row" draggable="true" data-id={o.id}>
            <span class="ord-handle" title="Drag to reorder">⠿</span>
            <span class="ord-grade mono">{o.grade}</span>
            <span class="ord-body">
              <span class="ord-name">{o.name}</span>
              <span class="ord-region muted">{o.region}{o.day_type ? ` · ${o.day_type === 'crag' ? '🪨' : '⛰️'}` : ''}</span>
            </span>
            {o.status === 'proposed' && <span class="ord-badge">proposed</span>}
          </div>
        ))}
      </div>

      {proposed.length > 0 && (
        <div class="card proposed-card">
          <h3>🧭 Shotgun's proposed alternatives <span class="tag suggested">{proposed.length}</span></h3>
          <p class="muted tiny">Scouted climbs (a pivot if one's too hard/easy). Review the dossier, then add it to your trip.</p>
          <div class="prop-list">
            {proposed.map((o) => (
              <div class="prop" data-prop={o.id}>
                <span class="p-emoji">🧗</span>
                <div class="p-meta">
                  <div class="p-name"><a href={`/objectives/${o.id}`} target="_blank">{o.name}</a> <span class="muted tiny">{o.grade} · {o.region}</span></div>
                  {o.note && <div class="muted p-sub">{o.note}</div>}
                </div>
                <div class="p-actions">
                  <button class="btn sm prop-add" data-id={o.id}>✓ Add to trip</button>
                  <button class="btn ghost sm prop-del" data-id={o.id}>✕</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {deferred.length > 0 && (
        <div class="card deferred-card">
          <h3>💤 Possible climbs <span class="tag muted">{deferred.length}</span></h3>
          <p class="muted tiny">Parked out of the active plan — too hard, off-season, or just maybes. Promote back when it fits, or cull. Not deleted, not on the public site.</p>
          <div class="prop-list">
            {deferred.map((o) => (
              <div class="prop" data-prop={o.id}>
                <span class="p-emoji">💤</span>
                <div class="p-meta">
                  <div class="p-name"><a href={`/objectives/${o.id}`} target="_blank">{o.name}</a> <span class="muted tiny">{o.grade} · {o.region}</span></div>
                  {o.note && <div class="muted p-sub">{o.note}</div>}
                </div>
                <div class="p-actions">
                  <button class="btn sm defer-promote" data-id={o.id}>↑ Back to trip</button>
                  <button class="btn ghost sm defer-cull" data-id={o.id}>✕</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- add objective -->
      <div class="card add-card">
        <h3>＋ Add an objective</h3>
        <div class="composer">
          <input id="o-name" placeholder="Name — e.g. Mt. Reynolds, Swiftsure Ridge" />
          <div class="composer-row">
            <input id="o-region" placeholder="Region (Glacier NP, MT)" />
            <input id="o-grade" placeholder="Grade (5.4 Alpine)" />
          </div>
          <div class="composer-row">
            <input id="o-commit" placeholder="Commitment (Full day / airy ridge)" />
            <input id="o-disc" placeholder="Discipline (alpine)" />
          </div>
          <div class="composer-row">
            <input id="o-hazard" placeholder="Key hazard (Choss & grizzlies)" />
            <select id="o-sev">{sevs.map((s) => <option value={s} selected={s === 'med'}>{s}</option>)}</select>
          </div>
          <div class="composer-foot">
            <span class="muted tiny">Shotgun fills the dossier on its next pass.</span>
            <button id="add-obj" class="btn">Add objective</button>
          </div>
        </div>
      </div>

      <!-- objectives -->
      <div id="rows" class="rows">
        {objectives.map((o) => {
          const seeds = seedsFor(o.id);
          return (
            <div class="obj card" data-id={o.id}>
              <div class="obj-top">
                <input class="o-name" data-field="name" value={o.name} placeholder="Name" />
                <span class="status">{o.beta ? <a href={`/objectives/${o.id}`} target="_blank" class="ready">📋 dossier</a> : <span class="pending">🔍 needs research</span>}</span>
                <button class="defer" title="Defer to the possible-climbs queue" aria-label="defer">💤</button>
                <button class="del" title="Delete" aria-label="delete">🗑️</button>
              </div>
              <div class="meta-row">
                <input class="sm" data-field="region" value={o.region ?? ''} placeholder="Region" />
                <input class="sm" data-field="grade" value={o.grade ?? ''} placeholder="Grade" />
                <input class="sm" data-field="discipline" value={o.discipline ?? ''} placeholder="Discipline" />
                <select class="sm" data-field="severity">{sevs.map((s) => <option value={s} selected={o.severity === s}>{s}</option>)}</select>
                <select class="sm" data-field="day_type" title="Crag (WFH) vs weekend alpine">{days.map(([val, l]) => <option value={val} selected={(o.day_type ?? '') === val}>{l}</option>)}</select>
              </div>
              <div class="meta-row">
                <input class="wide" data-field="commitment" value={o.commitment ?? ''} placeholder="Commitment" />
                <input class="wide" data-field="hazard" value={o.hazard ?? ''} placeholder="Key hazard" />
              </div>
              <div class="gpx-row">
                <span class="gpx-lbl">🛰️ GPX</span>
                {o.gpx_url
                  ? <span class="gpx-current"><a href={o.gpx_url} target="_blank" rel="noopener">⬇ track</a> <span class={`gpx-st ${o.gpx_verified ? 'ok' : 'prov'}`}>{o.gpx_verified ? '✓ verified' : '⚠ provisional — verify in Gaia'}</span></span>
                  : <span class="muted tiny gpx-current">none yet</span>}
                {o.gpx_url && !o.gpx_verified && <button class="btn ghost sm gpx-verify" type="button">Mark verified</button>}
                <label class="btn ghost sm gpx-up">⬆ Upload .gpx<input type="file" accept=".gpx" hidden /></label>
              </div>

              <details class="beta-edit">
                <summary>📋 Full dossier — trailhead · approach · rack · hazards…</summary>
                <div class="be-grid">
                  <label class="full">Summary<textarea data-b="summary">{(o.beta as any)?.summary ?? ''}</textarea></label>
                  <label>Trailhead name<input data-b="trailhead.name" value={(o.beta as any)?.trailhead?.name ?? ''} /></label>
                  <label>TH lat<input data-b="trailhead.lat" value={(o.beta as any)?.trailhead?.lat ?? ''} /></label>
                  <label>TH lng<input data-b="trailhead.lng" value={(o.beta as any)?.trailhead?.lng ?? ''} /></label>
                  <label class="full">Trailhead / drive directions<textarea data-b="trailhead.drive">{(o.beta as any)?.trailhead?.drive ?? ''}</textarea></label>
                  <label class="full">Approach<textarea data-b="approach">{(o.beta as any)?.approach ?? ''}</textarea></label>
                  <label class="full">Descent<textarea data-b="descent">{(o.beta as any)?.descent ?? ''}</textarea></label>
                  <label class="full">Season<input data-b="season" value={(o.beta as any)?.season ?? ''} /></label>
                  <label class="full">Rack<textarea data-b="rack">{(o.beta as any)?.rack ?? ''}</textarea></label>
                  <label>Ropes<input data-b="ropes" value={(o.beta as any)?.ropes ?? ''} /></label>
                  <label>Footwear<input data-b="footwear" value={(o.beta as any)?.footwear ?? ''} /></label>
                  <label class="full">Last services<input data-b="last_services" value={(o.beta as any)?.last_services ?? ''} /></label>
                  <label class="full">Cell signal<input data-b="signal" value={(o.beta as any)?.signal ?? ''} /></label>
                  <label class="full">Land &amp; passes<input data-b="land" value={(o.beta as any)?.land ?? ''} /></label>
                  <label class="full">Permits<input data-b="permits" value={(o.beta as any)?.permits ?? ''} /></label>
                  <label class="full">Hazards (one per line)<textarea data-b="hazards">{((o.beta as any)?.hazards ?? []).join('\n')}</textarea></label>
                  <label class="full">Nearby (one per line)<textarea data-b="nearby">{((o.beta as any)?.nearby ?? []).join('\n')}</textarea></label>
                </div>
                <div class="be-foot"><span class="muted tiny">Emergency, routes &amp; field-guide stay with Shotgun for now.</span><button class="btn sm be-save" type="button">Save dossier</button></div>
              </details>

              <div class="seeds">
                <div class="seeds-label">🔗 Seed links <span class="muted">— what Shotgun researches from</span></div>
                {seeds.length > 0 && (
                  <ul class="seed-list">
                    {seeds.map((s: any) => <li><a href={s.url} target="_blank" rel="noopener">{s.title || s.url}</a> {s.tag && <span class="mono muted">· {s.tag}</span>} <span class={`st ${s.status}`}>{s.status === 'enriched' ? '✓' : '⏳'}</span></li>)}
                  </ul>
                )}
                <div class="seed-add">
                  <input class="s-url" type="url" placeholder="https://… (MP / WTA / GPX / trip report)" />
                  <select class="s-tag">{TAGS.map((t) => <option value={t}>{t}</option>)}</select>
                  <button class="btn ghost sm seed-btn">＋ Seed</button>
                </div>
              </div>
            </div>
          );
        })}
      </div>
      <div id="toast" class="toast"></div>
    </div>
  </section>

  <script>
    const toastEl = document.getElementById('toast');
    const toast = (m, err = false) => { toastEl.textContent = m; toastEl.className = 'toast show' + (err ? ' err' : ''); setTimeout(() => toastEl.className = 'toast', 1600); };
    const post = async (url, body) => { const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }); const j = await r.json(); if (!j.ok) toast(j.error || 'Failed', true); return j; };
    const rid = () => (crypto.randomUUID ? crypto.randomUUID() : 'o-' + Math.random().toString(36).slice(2));

    // ── view toggle: Edit cards ⇄ Reorder list ──
    const orderList = document.getElementById('order-list');
    const vEdit = document.getElementById('view-edit');
    const vOrder = document.getElementById('view-order');
    const editEls = ['.proposed-card', '.add-card', '#rows'].map((s) => document.querySelector(s)).filter(Boolean);
    function showView(order) {
      orderList.hidden = !order;
      editEls.forEach((el) => (el.hidden = order));
      vOrder.classList.toggle('active', order);
      vEdit.classList.toggle('active', !order);
    }
    vEdit?.addEventListener('click', () => showView(false));
    vOrder?.addEventListener('click', () => showView(true));

    // ── drag-to-reorder the trip sequence ──
    let dragEl = null;
    orderList?.querySelectorAll('.ord-row').forEach((row) => {
      row.addEventListener('dragstart', () => { dragEl = row; setTimeout(() => row.classList.add('dragging'), 0); });
      row.addEventListener('dragend', () => { row.classList.remove('dragging'); dragEl = null; persistOrder(); });
    });
    orderList?.addEventListener('dragover', (e) => {
      e.preventDefault(); if (!dragEl) return;
      const after = afterEl(e.clientY);
      if (after == null) orderList.appendChild(dragEl); else orderList.insertBefore(dragEl, after);
    });
    function afterEl(y) {
      const els = [...orderList.querySelectorAll('.ord-row:not(.dragging)')];
      return els.reduce((closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = y - box.top - box.height / 2;
        return (offset < 0 && offset > closest.offset) ? { offset, element: child } : closest;
      }, { offset: -Infinity }).element;
    }
    let saveTimer;
    function persistOrder() {
      clearTimeout(saveTimer);
      saveTimer = setTimeout(async () => {
        const items = [...orderList.querySelectorAll('.ord-row')].map((r, i) => ({ id: r.dataset.id, sort: (i + 1) * 10 }));
        const j = await post('/api/objectives', { action: 'reorder', items });
        if (j.ok) toast('Order saved ✓');
      }, 400);
    }

    // inline edits
    document.querySelectorAll('.obj [data-field]').forEach((inp) => inp.addEventListener('change', async () => {
      const card = inp.closest('.obj');
      const j = await post('/api/objectives', { action: 'update', id: card.dataset.id, obj: { [inp.dataset.field]: inp.value } });
      if (j.ok) toast('Saved ✓');
    }));
    // delete
    document.querySelectorAll('.obj .del').forEach((b) => b.addEventListener('click', async () => {
      const card = b.closest('.obj');
      if (!confirm('Delete this objective?')) return;
      const j = await post('/api/objectives', { action: 'remove', id: card.dataset.id });
      if (j.ok) { card.remove(); toast('Deleted'); }
    }));
    // 💤 defer a climb → the possible-climbs queue (out of plan/beta, not deleted)
    document.querySelectorAll('.obj .defer').forEach((b) => b.addEventListener('click', async () => {
      const card = b.closest('.obj');
      const j = await post('/api/objectives', { action: 'defer', id: card.dataset.id });
      if (j.ok) { card.remove(); toast('💤 Deferred to possible climbs'); } else toast(j.error || 'Failed', true);
    }));
    // possible-climbs queue: promote back to the trip, or cull
    document.querySelectorAll('.deferred-card .defer-promote').forEach((b) => b.addEventListener('click', async () => {
      const j = await post('/api/objectives', { action: 'promote', id: b.dataset.id });
      if (j.ok) { b.closest('.prop').remove(); toast('↑ Back on the trip'); } else toast(j.error || 'Failed', true);
    }));
    document.querySelectorAll('.deferred-card .defer-cull').forEach((b) => b.addEventListener('click', async () => {
      if (!confirm('Remove this climb permanently?')) return;
      const j = await post('/api/objectives', { action: 'remove', id: b.dataset.id });
      if (j.ok) { b.closest('.prop').remove(); toast('Removed'); } else toast(j.error || 'Failed', true);
    }));
    // seed a link → pins to this objective, feeds Shotgun
    document.querySelectorAll('.obj .seed-btn').forEach((b) => b.addEventListener('click', async () => {
      const card = b.closest('.obj');
      const url = card.querySelector('.s-url').value.trim();
      if (!url) { toast('Paste a link', true); return; }
      const tag = card.querySelector('.s-tag').value;
      const j = await post('/api/sources', { action: 'add', source: { id: rid(), url, tag, objective_id: card.dataset.id } });
      if (j.ok) { toast('Seeded ✓ — Shotgun will read it'); location.reload(); }
    }));
    // add objective
    document.getElementById('add-obj').addEventListener('click', async () => {
      const v = (id) => (document.getElementById(id)).value.trim();
      const name = v('o-name'); if (!name) { toast('Name it first', true); return; }
      const obj = {
        id: rid(), name, region: v('o-region'), grade: v('o-grade'), commitment: v('o-commit'),
        discipline: v('o-disc'), hazard: v('o-hazard'), severity: (document.getElementById('o-sev')).value,
      };
      let j = await post('/api/objectives', { action: 'add', obj });
      if (j.dup && j.dupes?.length) {
        const d = j.dupes[0];
        const ok = confirm(`⚠ Possible duplicate of "${d.name}" (${Math.round(d.score * 100)}% name match${d.near_mi != null ? `, ~${d.near_mi} mi away` : ''}).\n\nThis catches the SAME route added twice — different routes on the same peak are fine to add.\n\nAdd it anyway?`);
        if (!ok) return;
        j = await post('/api/objectives', { action: 'add', obj: { ...obj, force: true } });
      }
      if (j.ok) location.reload();
    });

    // proposed alternatives → promote (add to trip) / dismiss
    document.querySelectorAll('.prop-add').forEach((b) => b.addEventListener('click', async () => {
      const j = await post('/api/objectives', { action: 'promote', id: b.dataset.id });
      if (j.ok) { toast('Added to your trip ✓'); location.reload(); }
    }));
    document.querySelectorAll('.prop-del').forEach((b) => b.addEventListener('click', async () => {
      if (!confirm('Dismiss this proposed climb?')) return;
      const j = await post('/api/objectives', { action: 'remove', id: b.dataset.id });
      if (j.ok) { b.closest('.prop')?.remove(); toast('Dismissed'); }
    }));

    // GPX: upload a real track (David's own from Gaia → marked verified) / mark a provisional one verified
    document.querySelectorAll('.obj').forEach((card) => {
      const id = card.dataset.id;
      const up = card.querySelector('.gpx-up input');
      up?.addEventListener('change', async () => {
        const file = up.files && up.files[0]; if (!file) return;
        toast('Uploading GPX…');
        const fd = new FormData(); fd.append('file', file); fd.append('id', id);
        const r = await fetch('/api/gpx', { method: 'POST', body: fd });
        const j = await r.json();
        if (j.ok) { toast('GPX saved ✓'); location.reload(); } else toast(j.error || 'Upload failed', true);
      });
      card.querySelector('.gpx-verify')?.addEventListener('click', async () => {
        const j = await post('/api/objectives', { action: 'update', id, obj: { gpx_verified: true } });
        if (j.ok) { toast('Marked verified ✓'); location.reload(); }
      });
      // Full-beta dossier save → merges the patch into the objective's beta jsonb
      card.querySelector('.be-save')?.addEventListener('click', async () => {
        const patch = {}; const th = {};
        card.querySelectorAll('[data-b]').forEach((el) => {
          const k = el.dataset.b; const v = el.value.trim();
          if (k.startsWith('trailhead.')) { const s = k.split('.')[1]; if (v) th[s] = (s === 'lat' || s === 'lng') ? parseFloat(v) : v; }
          else if (k === 'hazards' || k === 'nearby') { patch[k] = v ? v.split('\n').map((x) => x.trim()).filter(Boolean) : []; }
          else if (v) patch[k] = v;
        });
        if (Object.keys(th).length) patch.trailhead = th;
        const j = await post('/api/objectives', { action: 'update-beta', id, obj: { beta: patch } });
        if (j.ok) toast('Dossier saved ✓');
      });
    });
  </script>

  <style>
    .back { display: inline-block; margin-top: .5rem; font-size: .9rem; }
    .research-note { margin-top: .7rem; color: var(--amber); font-size: .9rem; }
    .view-toggle { display: flex; gap: .5rem; margin-bottom: 1.2rem; }
    .vt { background: var(--bg-2); border: 1px solid var(--border); border-radius: 999px; color: var(--muted); padding: .4rem .9rem; font: inherit; font-size: .85rem; cursor: pointer; }
    .vt.active { background: rgba(52,211,153,.12); border-color: var(--green); color: var(--green); font-weight: 700; }
    .order-list { display: grid; gap: .35rem; margin-bottom: 1.5rem; }
    .ord-hint { margin-bottom: .5rem; }
    .ord-row { display: flex; align-items: center; gap: .7rem; padding: .55rem .7rem; background: linear-gradient(180deg, var(--panel), var(--panel-2)); border: 1px solid var(--border); border-radius: 10px; }
    .ord-row.dragging { opacity: .5; border-color: var(--green); }
    .ord-handle { cursor: grab; color: var(--faint); font-size: 1.1rem; user-select: none; }
    .ord-handle:active { cursor: grabbing; }
    .ord-grade { font-size: .76rem; color: var(--muted); min-width: 6.5rem; white-space: nowrap; }
    .ord-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .1rem; }
    .ord-name { font-weight: 700; font-size: .9rem; }
    .ord-region { font-size: .75rem; }
    .ord-badge { font-size: .6rem; text-transform: uppercase; letter-spacing: .06em; color: var(--sky); border: 1px dashed rgba(56,189,248,.5); border-radius: 999px; padding: .1rem .4rem; white-space: nowrap; }
    @media (max-width: 560px) { .ord-grade { display: none; } }
    .add-card { margin-bottom: 1.5rem; }
    .proposed-card { margin-bottom: 1.5rem; border-color: rgba(56,189,248,.35); background: linear-gradient(180deg, rgba(56,189,248,.07), var(--panel)); }
    .tag { font-size: .7rem; padding: .1rem .5rem; border-radius: 999px; }
    .tag.suggested { background: rgba(56,189,248,.2); color: var(--sky); }
    .prop-list { display: grid; gap: .6rem; margin-top: .8rem; }
    .prop { display: flex; align-items: center; gap: .7rem; padding: .6rem .7rem; background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; }
    .p-emoji { font-size: 1.2rem; } .p-meta { flex: 1; } .p-name a { color: var(--text); } .p-name a:hover { color: var(--green); }
    .p-sub { font-size: .82rem; margin-top: .15rem; }
    .p-actions { display: flex; gap: .4rem; flex-wrap: wrap; }
    .composer { display: grid; gap: .6rem; }
    .composer input, .composer select { width: 100%; background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .65rem .8rem; font: inherit; }
    .composer-row { display: flex; gap: .6rem; }
    .composer-row > * { flex: 1; }
    .composer-foot { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .rows { display: grid; gap: .9rem; }
    .obj { display: grid; gap: .55rem; }
    .obj-top { display: flex; align-items: center; gap: .6rem; }
    .o-name { flex: 1; font-weight: 700; font-size: 1.05rem; }
    .status { font-size: .82rem; white-space: nowrap; }
    .status .ready { color: var(--green); text-decoration: none; }
    .status .pending { color: var(--amber); }
    .del { background: transparent; border: 1px solid var(--border); border-radius: 8px; cursor: pointer; padding: .35rem .5rem; }
    .del:hover { border-color: var(--red); }
    .defer { background: transparent; border: 1px solid var(--border); border-radius: 8px; cursor: pointer; padding: .35rem .5rem; }
    .defer:hover { border-color: var(--amber); }
    .obj input, .obj select { background: var(--bg-2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); padding: .5rem .6rem; font: inherit; }
