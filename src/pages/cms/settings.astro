---
import Base from '../../layouts/Base.astro';
import { getTenant } from '../../lib/data';
const tid = Astro.locals.tenantId;
const t = await getTenant(tid);
const linksText = (t?.support_links ?? []).map((l) => `${l.label} | ${l.url}`).join('\n');
const sharing = t?.location_sharing ?? 'approximate';
const isPublic = t?.visibility === 'public';
---
<Base title="D-Tours · Trip Settings">
  <section>
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow">⚙️ Settings</p>
        <h2>Trip settings</h2>
        <p>Make this trip yours — your tracker, your privacy, how people reach you, and how they can chip in.</p>
        <a href="/cms" class="muted back">← back to CMS</a>
      </div>

      <div class="card form">
        <label>Trip name<input id="s-name" value={t?.name ?? ''} /></label>
        <label>Tagline<input id="s-tagline" value={t?.tagline ?? ''} placeholder="Austin → Squamish · summer 2026" /></label>

        <h3>🛰️ Live tracking</h3>
        <label>Garmin inReach MapShare feed URL<input id="s-feed" value={t?.mapshare_feed_url ?? ''} placeholder="https://share.garmin.com/Feed/Share/yourname" /></label>
        <label>Location privacy
          <select id="s-sharing">
            <option value="precise" selected={sharing === 'precise'}>Precise — show my exact dot</option>
            <option value="approximate" selected={sharing === 'approximate'}>Approximate — ~city level (recommended)</option>
            <option value="off" selected={sharing === 'off'}>Off — hide my location from the public map</option>
          </select>
        </label>

        <h3>📇 Contact</h3>
        <label>Contact email<input id="s-email" value={t?.contact_email ?? ''} placeholder="you@email.com" /></label>
        <label>Contact phone — optional, enables iMessage<input id="s-phone" value={t?.contact_phone ?? ''} placeholder="12065551234" /></label>

        <h3>💸 Fuel-the-trip links</h3>
        <label>One per line, <code>Label | url</code><textarea id="s-links" rows="4" placeholder={"Venmo | https://venmo.com/u/you\nPayPal | https://paypal.me/you\nText me | sms:+12065551234"}>{linksText}</textarea></label>

        <h3>🔒 Visibility</h3>
        <label>Who can see this trip
          <select id="s-vis">
            <option value="private" selected={!isPublic}>Private — only me</option>
            <option value="public" selected={isPublic}>Public — share my plan</option>
          </select>
        </label>

        <div class="foot">
          <button id="save" class="btn">Save settings</button>
          <p class="msg" id="msg"></p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const msg = document.getElementById('msg');
    const v = (id) => (document.getElementById(id)).value.trim();
    document.getElementById('save').addEventListener('click', async () => {
      const support_links = (document.getElementById('s-links')).value
        .split('\n').map((l) => l.trim()).filter(Boolean)
        .map((l) => { const i = l.indexOf('|'); return i > 0 ? { label: l.slice(0, i).trim(), url: l.slice(i + 1).trim() } : null; })
        .filter(Boolean);
      const payload = {
        name: v('s-name'), tagline: v('s-tagline'), mapshare_feed_url: v('s-feed'),
        location_sharing: (document.getElementById('s-sharing')).value,
        contact_email: v('s-email'), contact_phone: v('s-phone'),
        support_links, visibility: (document.getElementById('s-vis')).value,
      };
      msg.textContent = 'Saving…'; msg.className = 'msg';
      const r = await fetch('/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const j = await r.json();
      msg.textContent = j.ok ? 'Saved ✓' : (j.error || 'Failed'); msg.className = 'msg ' + (j.ok ? 'ok' : 'err');
    });
  </script>

  <style>
    .container.narrow { width: min(100% - 2.5rem, 760px); }
    .back { display: inline-block; margin-top: .5rem; font-size: .9rem; }
    .form { display: grid; gap: .9rem; }
    .form h3 { margin: .6rem 0 -.2rem; font-size: 1rem; }
    .form label { display: grid; gap: .3rem; font-size: .85rem; font-weight: 600; color: var(--muted); }
    .form input, .form textarea, .form select { background: var(--bg-2); border: 1px solid var(--border); border-radius: 9px; color: var(--text); padding: .6rem .8rem; font: inherit; font-weight: 400; }
    .foot { display: flex; align-items: center; gap: 1rem; margin-top: .4rem; }
    .msg { margin: 0; font-size: .85rem; } .msg.ok { color: var(--green); } .msg.err { color: var(--red); }
  </style>
</Base>
