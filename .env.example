# ─── D-Tours environment ───────────────────────────────────────────────────
# Copy to `.env` and fill in. EVERYTHING is optional for local dev — with no
# secrets set, the app runs on mock data so you can click through immediately.

# ── Supabase (DB / auth / storage) ──
# Get these from your Supabase project → Settings → API
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=  # sb_publishable_... (safe in the browser, RLS-protected)
SUPABASE_SECRET_KEY=              # sb_secret_... server-only; NEVER expose or commit

# ── Live geo: Garmin inReach MapShare ──
# explore.garmin.com → Social → MapShare → Feeds → copy the Raw KML link.
# Leave the feed PASSWORD OFF so the poller can read it.
MAPSHARE_FEED_URL=

# ── Shotgun comms ──
# Email (nodemailer) — your SMTP creds (e.g. Gmail app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_FROM="Shotgun <shotgun@spacelabforever.com>"

# Where Shotgun pings David. Channel priority: imessage > email > sms > inreach
NOTIFY_EMAIL=me@davidpuerto.com
# Carrier email-to-SMS gateway for your OWN phone (free, no Twilio).
# Verizon: <number>@vtext.com · AT&T: @txt.att.net · T-Mobile: @tmomail.net
NOTIFY_SMS_GATEWAY=
# inReach: send a message TO your device via your Garmin-linked address (off-grid fallback)
NOTIFY_INREACH=

# Twilio — NOT used in v1. Stub stays dark unless these are set.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── D-Tours detour engine ──
GOOGLE_PLACES_API_KEY=            # optional; Overpass/Wikidata work key-free
# Overpass + Wikidata + iNaturalist + NWS need no key.
